import requests

def insert_deal(deal: dict, endpoint: str) -> str:
    # build the SOAP envelope, filling values from your deal dict
    xml_body = f"""<?xml version="1.0"?>
<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"
               xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <soap:Body>
    <WTDealImport xmlns="http://www.oati.net/namespace">
      <Deal>
        <Action>CreateNewDeal</Action>
        <ExternalKey>{deal['ExternalKey']}</ExternalKey>
        <DealType>{deal['DealType']}</DealType>
      </Deal>
    </WTDealImport>
  </soap:Body>
</soap:Envelope>"""

    headers = {
        "Content-Type": "text/xml; charset=utf-8",
        "SOAPAction": "http://www.oati.net/namespace/WTDealImport",  # confirm exact value
    }

    response = requests.post(endpoint, data=xml_body.encode("utf-8"), headers=headers)
    response.raise_for_status()
    return response.text   # the SOAP response XML

    result = insert_deal(deal, "https://your-webplus-host/path/to/service")
print(result)
