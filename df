def _friendly_when(state) -> str:
    """
    Human-friendly label for the requested schedule date, taken from the agent
    state's Start_Date (falls back to End_Date). Returns:
      - "today"       if the date is today
      - "yesterday"   if it is the previous day
      - "<d> <Month>" otherwise, e.g. "1 June"
      - "this date"   if no/invalid date is available (safe fallback)
    """
    raw = None
    try:
        raw = (state or {}).get("Start_Date") or (state or {}).get("End_Date")
    except Exception:
        raw = None
    if not raw:
        return "this date"
    try:
        d = parse_date(str(raw))
    except (ValueError, TypeError):
        return "this date"
    today = date.today()
    if d == today:
        return "today"
    if d == today - timedelta(days=1):
        return "yesterday"
    return f"{d.day} {d.strftime('%B')}"

