def build_dashboard_html(result: dict, template_path: str | Path) -> str:
    tags_src = (result or {}).get("Unschedule Tags") or []
    if not tags_src:
        return ""
    tags_json = json.dumps(_map_tags(tags_src), allow_nan=False, ensure_ascii=False)
    alloc = None
    for k in _ALLOC_KEYS:
        if (result or {}).get(k):
            alloc = result[k]; break
    alloc_json = json.dumps(alloc, allow_nan=False, ensure_ascii=False) if alloc else "null"
    template = Path(template_path).read_text(encoding="utf-8")
    injected = (f"const RESULT_ALLOCATION = {alloc_json};\n"
                f"    const ORIGINAL_TAGS_DB = {tags_json};")
    new, n = _TAGS_ASSIGN.subn(lambda m: injected, template, count=1)
    if n == 0:
        raise ValueError("Could not find 'const ORIGINAL_TAGS_DB = [...];' in the template.")
