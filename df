today = date.today()
 
    # 1) Relative words straight from the latest human prompt (dates may be None).
    try:
        for m in reversed((state or {}).get("messages", []) or []):
            if getattr(m, "type", "") != "human":
                continue
            content = getattr(m, "content", "")
            text = content if isinstance(content, str) else " ".join(str(p) for p in (content or []))
            low = text.lower()
            if "yesterday" in low:
                return "yesterday"
            if "today" in low:
                return "today"
            break  # only the most recent human turn is the active request
    except Exception:
        pass
 
    # 2) Fall back to the resolved Start_Date / End_Date (explicit calendar date).
    raw = None
    try:
        raw = (state or {}).get("Start_Date") or (state or {}).get("End_Date")
    except Exception:
        raw = None
    if not raw:
        return "this date"
    try:
        d = parse_date(str(raw))
    except (ValueError, TypeError):
        return "this date"
    if d == today:
        return "today"
    if d == today - timedelta(days=1):
        return "yesterday"
    return f"{d.day} {d.strftime('%B')}"
