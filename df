// Deal Number cell -> find the matching purchase/sale record, reuse showFlowTooltip
  function showRowDealTooltip(e, dealNumber, rowType) {
    const dn = String(dealNumber);
    if (rowType === 'PURCHASE') {
      const p = STATE.purchaseDeals.find(x => String(x.deal_num) === dn);
      if (p) return showFlowTooltip(e, 'PurchaseDeal', p.id, p.location);
    } else if (rowType === 'SALE') {
      const s = STATE.saleDeals.find(x => String(x.deal_num) === dn);
      if (s) return showFlowTooltip(e, 'SaleDeal', s.id, s.location);
    }
  }

  // Tag Code cell -> find the tag by code, reuse showFlowTooltip
  function showRowTagTooltip(e, tagCode) {
    const t = STATE.tags.find(x => x.tag_code === tagCode);
    if (t) return showFlowTooltip(e, 'Tag', t.id, t.location);
  }

// BEFORE
                  <td style="font-family:var(--mono); font-weight:600;">${String(r.deal_number)}</td>
// AFTER
                  <td style="font-family:var(--mono); font-weight:600; cursor:pointer;"
                      onmousemove="showRowDealTooltip(event, '${String(r.deal_number)}', '${r.type}')"
                      onmouseout="hideFlowTooltip()">${String(r.deal_number)}</td>

// BEFORE
         <td rowspan="${N}" style="font-family:var(--mono); color:var(--amber); vertical-align:middle;">${g.tag_code}</td>
