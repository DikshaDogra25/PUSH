# Sources that are placeholders, not literal values: their real sources are
# the quoted names in the description, e.g. "...like 'MIDC', 'BPA'".
EXPAND_SOURCES = {"other"}


def extract_sources_from_description(description: str) -> list[str]:
    """Pull quoted source names out of a description.
    Handles:  'MIDC'  |  'MIDC', 'BPA'  |  'MIDC, BPA'  |  "MIDC"
    """
    names = []
    for token in re.findall(r"['\"]([^'\"]+)['\"]", description or ""):
        names.extend(part.strip() for part in token.split(",") if part.strip())
    return names

