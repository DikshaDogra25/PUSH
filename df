// Trade date — single dynamic start date (ISO "YYYY-MM-DD").
  const TRADE_DATE = "2026-06-04";   // <- pipeline replaces this from ProfileDate
  function parseTradeDate(str) {
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(str || "");
    return m ? new Date(+m[1], +m[2] - 1, +m[3]) : null;
  }
  let selectedDate = parseTradeDate(TRADE_DATE) || new Date(2026, 5, 21);
  let currentCalendarDate = new Date(selectedDate);

function getFriendlyDateLabel(dateStr) {
    if (dateStr === "2026-06-21") return "2026-06-21 (Yesterday)";
    if (dateStr === "2026-06-22") return "2026-06-22 (Today)";
    return dateStr;
  }

function getFriendlyDateLabel(dateStr) {
    const today = new Date(); today.setHours(0, 0, 0, 0);
    const yest = new Date(today); yest.setDate(today.getDate() - 1);
    if (dateStr === formatDate(today)) return dateStr + " (Today)";
    if (dateStr === formatDate(yest)) return dateStr + " (Yesterday)";
    return dateStr;
  }


