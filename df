// BEFORE
      // Calculate warning state
      const locPurch = STATE.purchaseDeals.filter(p => p.location === loc.name);
      const purchSum = locPurch.reduce((sum, p) => sum + p.mw, 0);
      const hasDiscrepancy = Math.abs(loc.totalMW - purchSum) > 0.1;
      const isRejected = STATE.locationStates[loc.name] === 'Rejected';
      const hasWarning = hasDiscrepancy || isRejected;

      let warnIcon = "";
      if (hasWarning) {
        const titleText = isRejected ? "Location Rejected" : `Audit Mismatch: Purchases (${purchSum.toFixed(1)} MW) do not match Tags (${loc.totalMW.toFixed(1)} MW)`;
        warnIcon = `<i data-lucide="alert-triangle" style="color:var(--red); width:13px; height:13px; display:inline-block; vertical-align:middle; margin-left:6px;" title="${titleText}"></i>`;
      }


// AFTER
      // ---- Audit state: same Net Balance rule as the Location Audits panel ----
      const __fpAudit = (typeof FINAL_PLAN !== "undefined" && FINAL_PLAN) ? FINAL_PLAN : [];
      const __locTagCodes = new Set(STATE.tags.filter(t => t.location === loc.name).map(t => t.tag_code));
      const __locGroups = __fpAudit.filter(g => __locTagCodes.has(g.tag_code));

      let __purchSum = 0, __salesSum = 0;
      __locGroups.forEach(g => {
        (g.rows || []).forEach(r => {
          const v = Number(r.volume || 0);
          if (r.type === "PURCHASE") __purchSum += Math.abs(v);
          else if (r.type === "SALE") __salesSum += v;
        });
      });

      const isRejected = STATE.locationStates[loc.name] === 'Rejected';
      const netPassed = !isRejected && Math.abs(__salesSum - __purchSum) < 0.1;

      const auditTitle = isRejected
        ? "Location Rejected"
        : (netPassed
            ? `Net Balance: Passed (Purchases ${__purchSum.toFixed(1)} MW = Sales ${__salesSum.toFixed(1)} MW)`
            : `Net Balance: ${Math.abs(__salesSum - __purchSum).toFixed(1)} MW ${__salesSum > __purchSum ? 'Long' : 'Short'}`);

      const warnIcon = `<i data-lucide="${netPassed ? 'check-circle' : 'alert-triangle'}"
            style="color:var(${netPassed ? '--green' : '--red'}); width:14px; height:14px; display:inline-block; vertical-align:middle;"
            title="${auditTitle}"></i>`;


