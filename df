@dataclass
class RuleResult:
    kept: pd.DataFrame            # aggregated: Source = group key (e.g. "BPA ACS")
    kept_detailed: pd.DataFrame   # ungrouped: Source = actual source (e.g. "BPAPOWER")
    ruled_out: pd.DataFrame

blocks = [annotated[annotated["rule_id"] == rid] for rid in ordered_ids]
        kept = (pd.concat(blocks).reset_index(drop=True)
                if blocks else annotated.iloc[0:0].copy())

        return RuleResult(kept=kept, ruled_out=ruled_out)

blocks = [annotated[annotated["rule_id"] == rid] for rid in ordered_ids]
        kept = (pd.concat(blocks).reset_index(drop=True)
                if blocks else annotated.iloc[0:0].copy())

        # ungrouped view: same rows, Source shows the actual matched value
        kept_detailed = kept.copy()
        kept_detailed[col] = kept_detailed["Source_Temp"]

        return RuleResult(kept=kept, kept_detailed=kept_detailed, ruled_out=ruled_out)
