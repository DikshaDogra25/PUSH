# The requested date is carried in the get_purchase_deal_data tool call args
# (start_date/end_date), NOT in state["Start_Date"]/["End_Date"]. Pull it from
# the latest AIMessage's tool_calls, then fall back to state keys for safety.
raw = None
try:
    for m in reversed((state or {}).get("messages", []) or []):
        for tc in (getattr(m, "tool_calls", None) or []):
            args = (tc.get("args") if isinstance(tc, dict) else getattr(tc, "args", None)) or {}
            cand = args.get("start_date") or args.get("end_date")
            if cand:
                raw = cand
                break
        if raw:
            break
except Exception:
    raw = None
if not raw:                       # safety fallback to state keys
    try:
        raw = (state or {}).get("Start_Date") or (state or {}).get("End_Date")
    except Exception:
        raw = None
if not raw:
    return "this date"
