@staticmethod
def _build_sale_curves(product_list):
    """
    From Location Aggregation ProductA/ProductB, build per-source hourly supply curves.
    Returns (a_by_source, b_by_source), each: { source: {"product": str, "hours": {he:int -> mw:float}} }.
    First occurrence of a source wins (mirrors old sale_by_source). The aggregate 'All' row is skipped.
    """
    def index(entries):
        out = {}
        for e in (entries or []):
            if not isinstance(e, dict):
                continue
            src = Deal_Schedule_Plan._clean(e.get("CP"))
            if not src or src.lower() == "all":   # 'All' is an aggregate, not a real source
                continue
            if src in out:
                continue                          # first occurrence wins
            hours = {}
            for pt in (e.get("data") or []):
                if not isinstance(pt, dict):
                    continue
                try:
                    he = int(pt.get("HE"))
                except (TypeError, ValueError):
                    continue
                try:
                    val = float(pt.get("values"))
                except (TypeError, ValueError):
                    val = 0.0
                if val != val:                    # NaN
                    val = 0.0
                hours[he] = val
            out[src] = {"product": Deal_Schedule_Plan._clean(e.get("Product")), "hours": hours}
        return out



# saledeals now carries the Location Aggregation dict {"ProductA":[...], "ProductB":[...]}
a_by_source, b_by_source = Deal_Schedule_Plan._build_sale_curves(saledeals)


# ---------- SALE: Product A first, overflow to Product B (match on source only) ----------
src_key = Deal_Schedule_Plan._clean(tag.get("Source"))
a_entry = a_by_source.get(src_key)
b_entry = b_by_source.get(src_key)
a_hours = a_entry["hours"] if a_entry else {}
b_hours = b_entry["hours"] if b_entry else {}

saleA = [0.0] * len(HES)
saleB = [0.0] * len(HES)
sale_total = [0.0] * len(HES)
for j, he in enumerate(HES):
    n = need[j]
    a = min(n, a_hours.get(he, 0.0))                 # <-- need-cap. For verbatim A/B: a = a_hours.get(he, 0.0)
    a = a if a > 0 else 0.0
    saleA[j] = round(a, 4)
    b = min(n - a, b_hours.get(he, 0.0))             # overflow remainder into B (verbatim: b = b_hours.get(he, 0.0))
    b = b if b > 0 else 0.0
    saleB[j] = round(b, 4)
    sale_total[j] = a + b

# emit a leg row only when that source matched in the corresponding product list (mirrors old `if sa is not None`)
if a_entry is not None:
    rows.append({
        "type": "SALE",
        "product": "Product A",
        "deal_number": Deal_Schedule_Plan._sale_deal_number("A", src_key),
        "counterparty": a_entry.get("product") or "Amazon Energy Services",
        "mw": saleA,
        "volume": round(sum(saleA), 4),              # sale positive
    })
if b_entry is not None:
    rows.append({
        "type": "SALE",
        "product": "Product B",
        "deal_number": Deal_Schedule_Plan._sale_deal_number("B", src_key),
        "counterparty": b_entry.get("product") or "Amazon Energy Services",
        "mw": saleB,
        "volume": round(sum(saleB), 4),
    })

    pl = product_list or {}
    return index(pl.get("ProductA")), index(pl.get("ProductB"))
