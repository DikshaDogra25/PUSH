import copy
from langchain_core.tools import BaseTool

WT_TEMPLATE_TOOL = "query_wt_template"
THRESHOLD_MW = 150
COUNTERPARTY = "amazon"


def _get_tool(tools: list[BaseTool], name: str) -> BaseTool:
    for t in tools:
        if t.name == name:
            return t
    raise ValueError(f"Tool '{name}' not found")


# --- deterministic: aggregate by SOURCE, split A/B ---
def aggregate_and_categorize(state: AgentState) -> dict:
    by_source: dict[str, float] = {}
    for tag in state["tag_details"]:
        by_source[tag["source"]] = by_source.get(tag["source"], 0) + tag["mw"]

    product_a, product_b = [], []
    for source, total_mw in by_source.items():
        # Carbon Free + ACS booked to A up to 150 MW/h, rest to B
        if source in ("Carbon Free", "ACS"):
            a_mw = min(total_mw, THRESHOLD_MW)
            b_mw = total_mw - a_mw
            if a_mw > 0:
                product_a.append({"source": source, "mw": a_mw})
            if b_mw > 0:
                product_b.append({"source": source, "mw": b_mw})
        else:
            product_b.append({"source": source, "mw": total_mw})

    return {"product_a": product_a, "product_b": product_b}


# --- tool: fetch yesterday's WT templates ---
def make_fetch_template(tools: list[BaseTool]):
    tool = _get_tool(tools, WT_TEMPLATE_TOOL)

    def fetch_template(state: AgentState) -> dict:
        templates, errors = {}, list(state.get("errors", []))
        items = (
            [(i, "A") for i in state["product_a"]]
            + [(i, "B") for i in state["product_b"]]
        )
        seen = set()
        for item, product in items:
            key = (item["source"], product)
            if key in seen:
                continue
            seen.add(key)
            try:
                result = tool.invoke({
                    "source": item["source"],
                    "product": product,
                    "counterparty": COUNTERPARTY,
                    "date": state["deal_date"],
                })
                if result:
                    templates[key] = result
                else:
                    errors.append(f"No WT template for {key}")
            except Exception as e:
                errors.append(f"Template lookup failed for {key}: {e}")
        return {"templates": templates, "errors": errors}

    return fetch_template


# --- deterministic: clone template, inject MW + dates, stage ---
def build_deals(state: AgentState) -> dict:
    staged, errors = [], list(state.get("errors", []))
    items = (
        [(i, "A") for i in state["product_a"]]
        + [(i, "B") for i in state["product_b"]]
    )
    for item, product in items:
        key = (item["source"], product)
        template = state["templates"].get(key)
        if template is None:
            errors.append(f"Skipping {key}: no template")
            continue
        deal = copy.deepcopy(template)
        deal["mw"] = item["mw"]
        deal["product"] = product
        deal["source"] = item["source"]
        deal["counterparty"] = COUNTERPARTY
        deal["trade_date"] = state["trade_date"]
        deal["deal_date"] = state["deal_date"]
        deal["_status"] = "staged"   # not inserted
        staged.append(deal)
    return {"staged_sale_deals": staged, "errors": errors}
