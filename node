import copy
from langchain_core.tools import BaseTool

WT_PURCHASE_TOOL = "get_purchase_deal_data"
WT_SALES_TOOL = "get_sales_deal_data"
THRESHOLD_MW = 150
COUNTERPARTY = "Amazon"


def _get_tool(tools: list[BaseTool], name: str) -> BaseTool:
    for t in tools:
        if t.name == name:
            return t
    raise ValueError(f"Tool '{name}' not found in: {[t.name for t in tools]}")


# --- 1) fetch purchase deals + tags ---
def make_fetch_purchase(tools: list[BaseTool]):
    tool = _get_tool(tools, WT_PURCHASE_TOOL)

    async def fetch_purchase(state: AgentState) -> dict:
        result = await tool.ainvoke({
            "start_date": state["start_date"],
            "end_date": state["end_date"],
        })
        # result is [purchase_table, tag_table]
        purchase_deals = result[0] if len(result) > 0 else []
        tag_details = result[1] if len(result) > 1 else []
        print(f"fetch_purchase: {len(purchase_deals)} deals, {len(tag_details)} tags")
        return {"purchase_deals": purchase_deals, "tag_details": tag_details}

    return fetch_purchase


# --- 2) aggregate by SOURCE, split Product A/B ---
def aggregate_and_categorize(state: AgentState) -> dict:
    tag_details = state.get("tag_details", [])
    print(f"categorize: received {len(tag_details)} tags")

    by_source: dict[str, float] = {}
    for tag in tag_details:
        src = tag["source"]
        by_source[src] = by_source.get(src, 0) + tag["mw"]

    product_a, product_b = [], []
    for source, total_mw in by_source.items():
        if source in ("Carbon Free", "ACS"):
            a_mw = min(total_mw, THRESHOLD_MW)
            b_mw = total_mw - a_mw
            if a_mw > 0:
                product_a.append({"source": source, "mw": a_mw})
            if b_mw > 0:
                product_b.append({"source": source, "mw": b_mw})
        else:
            product_b.append({"source": source, "mw": total_mw})

    print(f"categorize returning: {len(product_a)} A, {len(product_b)} B")
    return {"product_a": product_a, "product_b": product_b}


# --- 3) fetch yesterday's WT sale templates ---
def make_fetch_template(tools: list[BaseTool]):
    tool = _get_tool(tools, WT_SALES_TOOL)

    async def fetch_template(state: AgentState) -> dict:
        product_a = state.get("product_a", [])
        product_b = state.get("product_b", [])
        print(f"fetch_template: {len(product_a)} A, {len(product_b)} B")

        templates, errors = {}, list(state.get("errors", []))
        items = [(i, "A") for i in product_a] + [(i, "B") for i in product_b]
        seen = set()
        for item, product in items:
            key = (item["source"], product)
            if key in seen:
                continue
            seen.add(key)
            try:
                result = await tool.ainvoke({
                    "start_date": state["deal_date"],
                    "end_date": state["deal_date"],
                    "source": item["source"],
                })
                if result:
                    templates[key] = result
                else:
                    errors.append(f"No template for {key}")
            except Exception as e:
                errors.append(f"Template lookup failed {key}: {e}")

        return {"templates": templates, "errors": errors}

    return fetch_template


# --- 4) clone template, inject MW + dates, stage ---
def build_deals(state: AgentState) -> dict:
    staged, errors = [], list(state.get("errors", []))
    product_a = state.get("product_a", [])
    product_b = state.get("product_b", [])
    templates = state.get("templates", {})

    items = [(i, "A") for i in product_a] + [(i, "B") for i in product_b]
    for item, product in items:
        key = (item["source"], product)
        template = templates.get(key)
        if template is None:
            errors.append(f"Skipping {key}: no template")
            continue
        deal = copy.deepcopy(template)
        deal["mw"] = item["mw"]
        deal["product"] = product
        deal["source"] = item["source"]
        deal["counterparty"] = COUNTERPARTY
        deal["trade_date"] = state["trade_date"]
        deal["deal_date"] = state["deal_date"]
        deal["_status"] = "staged"
        staged.append(deal)

    print(f"build_deals: staged {len(staged)}")
    return {"staged_sale_deals": staged, "errors": errors}
