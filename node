import copy
from langchain_core.tools import BaseTool
from .state import SalesAgentState

WT_TEMPLATE_TOOL = "query_wt_template"   # <-- name of your existing MCP tool
COUNTERPARTY = "amazon"


def _get_tool(tools: list[BaseTool], name: str) -> BaseTool:
    for t in tools:
        if t.name == name:
            return t
    raise ValueError(f"Tool '{name}' not found in provided tools")


def make_fetch_template(tools: list[BaseTool]):
    """Look up yesterday's matching sale deal for each (source, product)."""
    tool = _get_tool(tools, WT_TEMPLATE_TOOL)

    def fetch_template(state: SalesAgentState) -> dict:
        templates, errors = {}, []
        items = (
            [(i, "A") for i in state["product_a"]]
            + [(i, "B") for i in state["product_b"]]
        )
        seen = set()
        for item, product in items:
            source = item["source"]
            key = (source, product)
            if key in seen:
                continue
            seen.add(key)
            try:
                # MCP tools are sync-invoked the same way you do in do_tools
                result = tool.invoke({
                    "source": source,
                    "product": product,
                    "counterparty": COUNTERPARTY,
                    "date": state["deal_date"],   # yesterday handled tool-side, or pass explicitly
                })
                if result:
                    templates[key] = result
                else:
                    errors.append(f"No WT template for {key}")
            except Exception as e:
                errors.append(f"Template lookup failed for {key}: {e}")

        return {"templates": templates, "errors": errors}

    return fetch_template


def build_deals(state: SalesAgentState) -> dict:
    """Clone each template, inject aggregated MW + dates. Stage only."""
    staged, errors = [], list(state.get("errors", []))

    items = (
        [(i, "A") for i in state["product_a"]]
        + [(i, "B") for i in state["product_b"]]
    )

    for item, product in items:
        source = item["source"]
        key = (source, product)
        template = state["templates"].get(key)
        if template is None:
            errors.append(f"Skipping {key}: no template available")
            continue

        deal = copy.deepcopy(template)   # structure from yesterday's deal
        deal["mw"] = item["mw"]          # the only quantity we override
        deal["product"] = product
        deal["source"] = source
        deal["counterparty"] = COUNTERPARTY
        deal["trade_date"] = state["trade_date"]
        deal["deal_date"] = state["deal_date"]
        deal["_status"] = "staged"       # marker: not yet inserted

        # --- DB INSERT WOULD GO HERE LATER ---
        # insert_tool.invoke({"deal": deal})  # when you wire the insert MCP tool
        staged.append(deal)

    return {"staged_sale_deals": staged, "errors": errors}
