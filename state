from typing import TypedDict, Optional
from langchain_core.tools import BaseTool


class SalesAgentState(TypedDict):
    # Input handed in from the first agent
    product_a: list[dict]          # aggregated MWs categorized as Product A
    product_b: list[dict]          # aggregated MWs categorized as Product B
    trade_date: str
    deal_date: str

    # Intermediate
    templates: dict                # keyed by (source, product) -> template deal

    # Output
    staged_sale_deals: list[dict]  # ready-to-review, NOT yet inserted
    errors: list[str]
