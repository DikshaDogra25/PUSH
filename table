      xmlBlock.style.display = "none";
    }

    infoBlock.innerHTML = infoHTML;
    timeline.innerHTML = "";
    logs.forEach(l => {
      timeline.innerHTML += `
        <div class="timeline-item">
          <div class="timeline-dot ${l.type}"></div>
          <div class="timeline-details">
            <div class="timeline-time">${l.time}</div>
            <div class="timeline-text">${l.text}</div>
          </div>
        </div>
      `;
    });

    if (xml) {
      document.getElementById("drawer-xml-payload").innerText = xml;
    }

    drawer.classList.add("active");
    overlay.classList.add("active");
  }

  function closeDrawer() {
    document.getElementById("detail-drawer").classList.remove("active");
    document.getElementById("detail-drawer-overlay").classList.remove("active");
    currentDrawerEntity = null;
  }

  function openConfigDrawer() {
    const drawer = document.getElementById("detail-drawer");
    const overlay = document.getElementById("detail-drawer-overlay");
    if (!drawer || !overlay) return;
    
    document.getElementById("drawer-title").innerText = `Engine Configurations`;
    
    // Toggle container display
    document.getElementById("drawer-entity-details").style.display = "none";
    document.getElementById("drawer-settings-config").style.display = "flex";
    
    drawer.classList.add("active");
    overlay.classList.add("active");
    
    if (window.lucide) {
      lucide.createIcons();
    }
  }

  function toggleDataScenario() {
    STATE.dataScenario = STATE.dataScenario === 'balanced' ? 'discrepancy' : 'balanced';
    
    const icon = document.getElementById("scenario-toggle-icon");
    const btn = document.getElementById("scenario-toggle-btn");
    
    if (STATE.dataScenario === 'balanced') {
      STATE.locationStates['PJM_WEST'] = 'Accepted';
      if (icon) {
        icon.style.color = "var(--green)";
      }
      if (btn) {
        btn.title = "Simulate Discrepancy Scenario (Current: Balanced)";
      }
      showToast("Balanced Data Scenario", "Mock data reset. All location audits are passing successfully.", "success");
    } else {
      STATE.locationStates['PJM_WEST'] = 'Rejected';
      if (icon) {
        icon.style.color = "var(--red)";
      }
      if (btn) {
        btn.title = "Simulate Balanced Scenario (Current: Discrepancy)";
      }
      showToast("Discrepancy Data Scenario", "Simulated PJM West mismatch and NP15 audit warnings.", "warning");
    }
    
    runAllocationEngine();
    renderAll();
    
    if (window.lucide) {
      lucide.createIcons();
    }
  }

  function saveDrawerMw() {
    if (!currentDrawerEntity || !STATE.manualMode) return;
    
    const { type, id } = currentDrawerEntity;
    
    let location = "";
    if (type === "Tag") {
      const entity = STATE.tags.find(t => t.id === id);
      if (entity) location = entity.location;
    } else if (type === "PurchaseDeal") {
      const entity = STATE.purchaseDeals.find(p => p.id === id);
      if (entity) location = entity.location;
    }
    
    if (location && getLocationState(location) === "Committed") {
      alert("This location schedule is committed and locked. Modifications are disabled.");
      return;
    }
    
    const inputVal = parseInt(document.getElementById("drawer-mw-input").value);
    if (isNaN(inputVal) || inputVal < 0) {
      alert("Please enter a valid MW number");
      return;
    }
    
    if (type === "Tag") {
      const entity = STATE.tags.find(t => t.id === id);
      entity.mw = inputVal;
    } else if (type === "PurchaseDeal") {
      const entity = STATE.purchaseDeals.find(p => p.id === id);
      entity.mw = inputVal;
    }

    runAllocationEngine();
    renderAll();
    openDrawer(type, id); // refresh drawer content
    alert("MW value successfully updated. Ledger and balancing state recalculated.");
  }

  // =========================================================================
  // OVERVIEW TAB VISUALS & PURCHASE DEALS TAB RENDERERS
  // =========================================================================
  function getFilteredOverviewLocations() {
    const searchInput = document.getElementById("overview-loc-search");
    const query = searchInput ? searchInput.value.toLowerCase().trim() : "";
    return STATE.locations.filter(loc => {
      const matchesQuery = loc.name.toLowerCase().includes(query);
      const locState = getLocationState(loc.name);
      let matchesFilter = true;
      if (STATE.overviewLocFilter !== 'All') {
        matchesFilter = (locState === STATE.overviewLocFilter);
      }
      return matchesQuery && matchesFilter;
    });
  }

  function setOverviewLocFilter(filterKey) {
    STATE.overviewLocFilter = filterKey;
    renderOverviewTab();
  }

  function toggleLocationActionDropdown(event) {
    event.stopPropagation();
    const menu = document.getElementById("loc-action-dropdown-menu");
    if (menu) {
      menu.style.display = menu.style.display === "block" ? "none" : "block";
    }
  }

  function changeLocationState(newState) {
    const locName = STATE.selectedLocName;
    if (!locName) return;
    if (getLocationState(locName) === 'Committed') {
      showToast("Already Committed", "This location schedule is committed and locked.", "info");
      return;
    }
    STATE.locationStates[locName] = newState;
    STATE.tags.forEach(t => {
      if (t.location === locName && t.status !== 'Committed') {
        t.status = newState;
      }
    });
    showToast(`Location ${newState}`, `Schedule for ${locName} has been marked as ${newState.toLowerCase()}.`, newState === "Accepted" ? "success" : "info");
    renderAll();
  }

  function renderOverviewTab() {
    // 1. Render filter pills with count badges
    const filterPillsContainer = document.getElementById("overview-loc-filter-pills");
    if (filterPillsContainer) {
      const allCount = STATE.locations.length;
      const draftCount = STATE.locations.filter(l => getLocationState(l.name) === 'Draft').length;
      const acceptedCount = STATE.locations.filter(l => getLocationState(l.name) === 'Accepted').length;
      const rejectedCount = STATE.locations.filter(l => getLocationState(l.name) === 'Rejected').length;
      const committedCount = STATE.locations.filter(l => getLocationState(l.name) === 'Committed').length;

      const filters = [
        { key: 'All', label: 'All', count: allCount, color: 'var(--ink-dim)' },
        { key: 'Draft', label: 'Draft', count: draftCount, color: 'var(--cyan)' },
        { key: 'Accepted', label: 'Accepted', count: acceptedCount, color: 'var(--green)' },
        { key: 'Rejected', label: 'Rejected', count: rejectedCount, color: 'var(--red)' },
        { key: 'Committed', label: 'Committed', count: committedCount, color: 'var(--green)' }
      ];

      filterPillsContainer.innerHTML = filters.map(f => {
        const isActive = STATE.overviewLocFilter === f.key;
        const activeBg = isActive ? 'rgba(255, 255, 255, 0.08)' : 'rgba(255, 255, 255, 0.01)';
        const activeBorder = isActive ? `1px solid ${f.color}` : '1px solid var(--border-light)';
        const activeTextColor = isActive ? '#fff' : 'var(--ink-dim)';
        
        let countBadgeColor = 'rgba(255, 255, 255, 0.08)';
        if (isActive) {
          if (f.key === 'Accepted') countBadgeColor = 'rgba(20, 153, 116, 0.2)';
          else if (f.key === 'Rejected') countBadgeColor = 'rgba(214, 69, 91, 0.2)';
          else if (f.key === 'Draft') countBadgeColor = 'rgba(6, 182, 212, 0.2)';
          else countBadgeColor = 'rgba(255, 255, 255, 0.15)';
        }

        return `
          <button onclick="setOverviewLocFilter('${f.key}')" style="display: flex; align-items: center; gap: 4px; padding: 3px 8px; font-size: 10px; font-weight: 500; font-family: var(--sans); background: ${activeBg}; border: ${activeBorder}; border-radius: 99px; color: ${activeTextColor}; cursor: pointer; transition: var(--transition);" class="loc-filter-pill">
            <span>${f.label}</span>
            <span style="font-size: 8px; font-family: var(--mono); background: ${countBadgeColor}; color: ${isActive ? f.color : 'var(--ink-dim)'}; padding: 1px 4px; border-radius: 99px; font-weight: 700;">${f.count}</span>
          </button>
        `;
      }).join('');
    }

    // 2. Populate Left Column: Selectable list of source locations
    const maxMW = STATE.locations[0]?.totalMW || 1;
    const listContainer = document.getElementById("overview-loc-list");
    if (listContainer) {
      listContainer.innerHTML = "";
      
      const filteredLocations = getFilteredOverviewLocations();
      
      if (filteredLocations.length === 0) {
        listContainer.innerHTML = `<div style="color:var(--ink-dim); font-size:10px; text-align:center; font-style:italic; padding: 20px 0;">No matching locations</div>`;
      } else {
        filteredLocations.forEach((loc) => {
          const originalIndex = STATE.locations.findIndex(l => l.name === loc.name);
          const pct = Math.round((loc.totalMW / maxMW) * 100);
          const activeClass = (loc.name === STATE.selectedLocName) ? "active" : "";
          
          // Check mismatch for this location
          const locPurchases = STATE.purchaseDeals.filter(p => p.location === loc.name);
          const purchasesTotalSum = locPurchases.reduce((sum, p) => sum + p.mw, 0);
          const salesTotalSum = loc.allocA + loc.allocB;
          const mismatchDiff = purchasesTotalSum - salesTotalSum;
          const isMismatched = Math.abs(mismatchDiff) > 0.1;
          
          let statusDotColor = "var(--green)";
          if (isMismatched) {
            statusDotColor = mismatchDiff < 0 ? "var(--red)" : "var(--amber)";
          }
          const locState = getLocationState(loc.name);
          
          let cardBorderColor = 'rgba(255, 255, 255, 0.05)';
          let cardBg = 'var(--surface-input)';

          if (activeClass) {
            cardBorderColor = 'var(--border-focus)';
            cardBg = 'rgba(6, 182, 212, 0.04)';
          }
 
          let stateBadge = '';
          if (locState === 'Accepted') {
            stateBadge = `<span style="font-size: 8px; color: var(--green); font-weight: 700; text-transform: uppercase; background: rgba(20, 153, 116, 0.12); padding: 1px 5px; border-radius: 3px; display: inline-flex; align-items: center; gap: 2px;" title="Accepted"><i data-lucide="check" style="width: 9px; height: 9px;"></i> ACCEPTED</span>`;
          } else if (locState === 'Rejected') {
            stateBadge = `<span style="font-size: 8px; color: var(--red); font-weight: 700; text-transform: uppercase; background: rgba(214, 69, 91, 0.12); padding: 1px 5px; border-radius: 3px; display: inline-flex; align-items: center; gap: 2px;" title="Rejected"><i data-lucide="x" style="width: 9px; height: 9px;"></i> REJECTED</span>`;
          } else if (locState === 'Committed') {
            stateBadge = `<span style="font-size: 8px; color: var(--cyan); font-weight: 700; text-transform: uppercase; background: rgba(0, 210, 196, 0.12); padding: 1px 5px; border-radius: 3px; display: inline-flex; align-items: center; gap: 2px; border: 1px solid rgba(0,210,196,0.3);" title="Scheduled"><i data-lucide="shield" style="width: 9px; height: 9px;"></i> SCHEDULED</span>`;
          }
 
          let productText = "ACS Energy";
          if (loc.allocA > 0 && loc.allocB > 0) {
            productText = "ACS & Carbon Free";
          } else if (loc.allocB > 0) {
            productText = "Carbon Free";
          }
 
          const itemHTML = `
            <div class="horiz-rule-item clickable ${activeClass}" onclick="selectOverviewLocation('${loc.name}')" style="padding: 6px 8px; border-radius: var(--radius-sm); border: 1px solid ${cardBorderColor}; background: ${cardBg}; transition: var(--transition); cursor: pointer;">
              <div class="horiz-rule-header" style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                <span class="horiz-rule-title" style="font-size:11px; font-weight:600; display:flex; align-items:center; gap:5px; min-width: 0; flex: 1;">
                  <span class="status-dot" style="background:${statusDotColor}; width:6px; height:6px; border-radius:50%; display:inline-block; flex-shrink: 0;"></span>
                  <strong style="color:var(--cyan); font-family:var(--brand); font-size:11px; flex-shrink: 0;">#${originalIndex + 1}</strong> 
                  <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${loc.name}</span>
                </span>
                <span class="horiz-rule-percent" style="font-family:var(--mono); font-size:10px; font-weight:600; color:var(--ink-primary); margin-left: 8px; flex-shrink: 0;">${(loc.totalMW / 24).toFixed(1)} MWh</span>
              </div>
              <div class="horiz-bar-bg" style="height:3px; background:rgba(255,255,255,0.03); border-radius:1.5px; margin: 4px 0; width:100%; position:relative; overflow:hidden;">
                <div class="horiz-bar-fill slate" style="width: ${pct}%; height:100%; background: ${activeClass ? 'var(--cyan)' : 'var(--ink-muted)'}; border-radius:1.5px;"></div>
              </div>
              <div style="font-size:8px; color:var(--ink-dim); display:flex; justify-content:space-between; align-items:center; width:100%; margin-top: 2px;">
                <span>Product: <span style="font-weight:600; color:var(--ink-secondary); font-size:8px;">${productText}</span></span>
                <div style="display: flex; align-items: center; gap: 4px; flex-shrink: 0;">
                  ${stateBadge ? stateBadge : `<span style="font-size:8px; color:var(--ink-dim);">A:${loc.allocA.toFixed(0)}|B:${loc.allocB.toFixed(0)}</span>`}
                </div>
              </div>
            </div>
          `;
          listContainer.insertAdjacentHTML("beforeend", itemHTML);
        });
      }
    }

    // 3. Get Active Location
    const visibleLocs = getFilteredOverviewLocations();
    let activeLoc = visibleLocs.find(l => l.name === STATE.selectedLocName);
    if (!activeLoc && visibleLocs.length > 0) {
      activeLoc = visibleLocs[0];
      STATE.selectedLocName = activeLoc.name;
    }
    if (!activeLoc) {
      activeLoc = STATE.locations.find(l => l.name === STATE.selectedLocName) || STATE.locations[0];
    }
    
    if (!activeLoc) return;

    // Update active location's accept/reject buttons dynamically in the Details Panel
    const buttonsContainer = document.getElementById("loc-action-buttons-container");
    if (buttonsContainer) {
      const locState = getLocationState(activeLoc.name);
      if (locState === 'Committed') {
        buttonsContainer.innerHTML = `
          <button class="btn-action" disabled style="padding: 4px 10px; font-size: 11px; border: 1px solid var(--border-light); color: var(--ink-muted); background: rgba(255,255,255,0.03); display: inline-flex; align-items: center; gap: 6px; cursor: not-allowed; border-radius: 4px; height: 24px;" title="This location schedule is committed and locked.">
            <i data-lucide="shield" style="width: 13px; height: 13px;"></i> Committed & Locked
          </button>
        `;
      } else if (locState === 'Accepted') {
        buttonsContainer.innerHTML = `
          <button class="btn-action btn-primary" onclick="toggleLocationActionDropdown(event)" style="padding: 4px 10px; font-size: 11px; border: 1px solid var(--green); color: #fff; background: var(--green); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; border-radius: 4px; height: 24px;" title="Accepted - Click to change state">
            <i data-lucide="check" style="width: 13px; height: 13px;"></i> Accepted <i data-lucide="chevron-down" style="width: 11px; height: 11px;"></i>
          </button>
          <div id="loc-action-dropdown-menu" style="display: none; position: absolute; top: 100%; right: 0; margin-top: 4px; background: #101015; border: 1px solid var(--border-hover); border-radius: 4px; box-shadow: var(--shadow-md); z-index: 100; min-width: 130px; overflow: hidden;">
            <button onclick="changeLocationState('Rejected')" style="width: 100%; text-align: left; padding: 6px 12px; font-size: 11px; background: transparent; border: none; color: var(--red); cursor: pointer; font-family: var(--sans); display: flex; align-items: center; gap: 6px;" onmouseover="this.style.background='rgba(214, 69, 91, 0.08)'" onmouseout="this.style.background='transparent'">
              <i data-lucide="x" style="width: 11px; height: 11px;"></i> Mark as Rejected
            </button>
          </div>
        `;
      } else if (locState === 'Rejected') {
        buttonsContainer.innerHTML = `
          <button class="btn-action" onclick="toggleLocationActionDropdown(event)" style="padding: 4px 10px; font-size: 11px; border: 1px solid var(--red); color: var(--red); background: rgba(214, 69, 91, 0.05); display: inline-flex; align-items: center; gap: 6px; cursor: pointer; border-radius: 4px; height: 24px;" title="Rejected - Click to change state">
            <i data-lucide="x" style="width: 13px; height: 13px;"></i> Rejected <i data-lucide="chevron-down" style="width: 11px; height: 11px;"></i>
          </button>
          <div id="loc-action-dropdown-menu" style="display: none; position: absolute; top: 100%; right: 0; margin-top: 4px; background: #101015; border: 1px solid var(--border-hover); border-radius: 4px; box-shadow: var(--shadow-md); z-index: 100; min-width: 130px; overflow: hidden;">
            <button onclick="changeLocationState('Accepted')" style="width: 100%; text-align: left; padding: 6px 12px; font-size: 11px; background: transparent; border: none; color: var(--green); cursor: pointer; font-family: var(--sans); display: flex; align-items: center; gap: 6px;" onmouseover="this.style.background='rgba(20, 153, 116, 0.08)'" onmouseout="this.style.background='transparent'">
              <i data-lucide="check" style="width: 11px; height: 11px;"></i> Mark as Accepted
            </button>
          </div>
        `;
      } else {
        buttonsContainer.innerHTML = `
          <button class="btn-action" onclick="rejectCurrentLocation()" style="padding: 4px 10px; font-size: 11px; border: 1px solid var(--red); color: var(--red); background: rgba(214, 69, 91, 0.05); display: flex; align-items: center; gap: 4px; cursor: pointer; border-radius: 4px; height: 24px;" title="Reject this schedule location">
            <i data-lucide="x" style="width: 13px; height: 13px;"></i> Reject
          </button>
          <button class="btn-action btn-primary" onclick="acceptCurrentLocation()" style="padding: 4px 10px; font-size: 11px; border: 1px solid var(--green); color: #fff; background: var(--green); display: flex; align-items: center; gap: 4px; cursor: pointer; border-radius: 4px; height: 24px;" title="Accept this schedule location">
            <i data-lucide="check" style="width: 13px; height: 13px;"></i> Accept
          </button>
        `;
      }
    }

    // Render flow diagram for active location
    renderLocReconWireframe(activeLoc);

    // Color location titles dynamically based on mismatch status
    const activeLocPurchases = STATE.purchaseDeals.filter(p => p.location === activeLoc.name);
    const activePurchasesTotal = activeLocPurchases.reduce((sum, p) => sum + p.mw, 0);
    const activeSalesTotal = activeLoc.allocA + activeLoc.allocB;
    const activeIsMismatched = Math.abs(activePurchasesTotal - activeSalesTotal) > 0.1;
    const activeTitleColor = activeIsMismatched ? "var(--red)" : "var(--cyan)";

    // Update titles for both Clearance and Flow cards
    const clearanceTitle = document.getElementById("clearance-title-loc");
    if (clearanceTitle) {
      clearanceTitle.innerText = activeLoc.name;
      clearanceTitle.style.color = activeTitleColor;
    }

    const summaryTitle = document.getElementById("summary-flow-title-loc");
    if (summaryTitle) {
      summaryTitle.innerText = activeLoc.name;
      summaryTitle.style.color = activeTitleColor;
    }

    // Render Yesterday's Clearance chart for the selected location
    renderSourceClearanceChart(activeLoc);

    // Populate Location Audits checks panel
    const locPurchases = STATE.purchaseDeals.filter(p => p.location === activeLoc.name);
    const purchasesTotalSum = locPurchases.reduce((sum, p) => sum + p.mw, 0);
    const salesTotalSum = activeLoc.allocA + activeLoc.allocB;
    const netDiff = salesTotalSum - purchasesTotalSum;
    const netBalanced = Math.abs(netDiff) < 0.1;

    // Check tags matching sale deals for energy flow check
    const activeLocTags = STATE.tags.filter(t => t.location === activeLoc.name);
    const tagsTotalSum = activeLocTags.reduce((sum, t) => sum + t.mw, 0);
    const energyFlowMatched = Math.abs(tagsTotalSum - salesTotalSum) < 0.1;

    let demandSalesMatch = true;
    for (let h = 0; h < 24; h++) {
      if (Math.abs(activeLoc.profileTotal[h] - (activeLoc.profileA[h] + activeLoc.profileB[h])) > 0.1) {
        demandSalesMatch = false;
        break;
      }
    }

    let capExceeded = false;
    for (let h = 0; h < 24; h++) {
      if (activeLoc.profileA[h] > STATE.limitA) {
        capExceeded = true;
        break;
      }
    }

    let checksHTML = "";
    
    // Check 1: Net Balance
    if (netBalanced) {
      checksHTML += `
        <div style="display:flex; align-items:center; gap:8px; color:var(--ink-secondary); cursor: pointer;" onmousemove="showAuditTooltip(event, 'NetBalance')" onmouseout="hideAuditTooltip()">
          <i data-lucide="check-circle" style="color:var(--green); width:14px; height:14px; flex-shrink:0;"></i>
          <span>Net Balance: <strong style="color:var(--green)">Passed</strong></span>
        </div>
      `;
    } else {
      const color = netDiff > 0 ? "var(--red)" : "var(--amber)";
      const icon = netDiff > 0 ? "x-circle" : "alert-triangle";
      const status = netDiff > 0 ? "Short" : "Long";
      checksHTML += `
        <div style="display:flex; align-items:center; gap:8px; color:var(--ink-secondary); cursor: pointer;" onmousemove="showAuditTooltip(event, 'NetBalance')" onmouseout="hideAuditTooltip()">
          <i data-lucide="${icon}" style="color:${color}; width:14px; height:14px; flex-shrink:0;"></i>
          <span>Net Balance: <strong style="color:${color}">${Math.abs(netDiff).toFixed(1)} MW ${status}</strong></span>
        </div>
      `;
    }

    // Check 2: Allocation Balance
    if (demandSalesMatch) {
      checksHTML += `
        <div style="display:flex; align-items:center; gap:8px; color:var(--ink-secondary); cursor: pointer;" onmousemove="showAuditTooltip(event, 'AllocBalance')" onmouseout="hideAuditTooltip()">
          <i data-lucide="check-circle" style="color:var(--green); width:14px; height:14px; flex-shrink:0;"></i>
          <span>Allocation Balance: <strong style="color:var(--green)">Passed</strong></span>
        </div>
      `;
    } else {
      checksHTML += `
        <div style="display:flex; align-items:center; gap:8px; color:var(--ink-secondary); cursor: pointer;" onmousemove="showAuditTooltip(event, 'AllocBalance')" onmouseout="hideAuditTooltip()">
          <i data-lucide="x-circle" style="color:var(--red); width:14px; height:14px; flex-shrink:0;"></i>
          <span>Allocation Balance: <strong style="color:var(--red)">Imbalance</strong></span>
        </div>
      `;
    }

    // Check 3: Product A Hourly Cap
    if (!capExceeded) {
      checksHTML += `
        <div style="display:flex; align-items:center; gap:8px; color:var(--ink-secondary); cursor: pointer;" onmousemove="showAuditTooltip(event, 'ProdACap')" onmouseout="hideAuditTooltip()">
          <i data-lucide="check-circle" style="color:var(--green); width:14px; height:14px; flex-shrink:0;"></i>
          <span>Product A Cap: <strong style="color:var(--green)">&lt; ${STATE.limitA}MW Cap</strong></span>
        </div>
      `;
    } else {
      checksHTML += `
        <div style="display:flex; align-items:center; gap:8px; color:var(--ink-secondary); cursor: pointer;" onmousemove="showAuditTooltip(event, 'ProdACap')" onmouseout="hideAuditTooltip()">
          <i data-lucide="alert-triangle" style="color:var(--amber); width:14px; height:14px; flex-shrink:0;"></i>
          <span>Product A Cap: <strong style="color:var(--amber)">Exceeds ${STATE.limitA}MW</strong></span>
        </div>
      `;
    }

    // Check 4: Energy Flow Check (Tag vs Sales)
    if (energyFlowMatched) {
      checksHTML += `
        <div style="display:flex; align-items:center; gap:8px; color:var(--ink-secondary); cursor: pointer;" onmousemove="showAuditTooltip(event, 'EnergyFlow')" onmouseout="hideAuditTooltip()">
          <i data-lucide="check-circle" style="color:var(--green); width:14px; height:14px; flex-shrink:0;"></i>
          <span>Energy Flow: <strong style="color:var(--green)">Passed</strong></span>
        </div>
      `;
    } else {
