  // Draw 24-Hour Product A/B stacked bar chart for selected location
  function renderLocProfileChartStacked(loc) {
    const svgContainer = document.getElementById("loc-profile-svg-container");
    if (!svgContainer) return;

    const profile = loc.profileTotal;
    const maxVal = Math.max(...profile, 1);
    const yAxisMax = Math.ceil((maxVal * 1.1) / 10) * 10 || 10;

    let svg = `<svg viewBox="0 0 620 200" style="width:100%; height:100%; display:block;">`;

    // Grid lines
    const ticks = [yAxisMax * 0.25, yAxisMax * 0.5, yAxisMax * 0.75, yAxisMax];
    ticks.forEach(tick => {
      const rounded = Math.round(tick * 10) / 10;
      const y = 160 - (tick * 130 / yAxisMax);
      svg += `<line x1="45" y1="${y}" x2="590" y2="${y}" stroke="var(--border-light)" stroke-dasharray="3,3" />`;
      svg += `<text x="15" y="${y + 3}" fill="var(--ink-dim)" font-family="var(--mono)" font-size="8px">${rounded}</text>`;
    });

    // 150 MWh Cap horizontal threshold line
    if (yAxisMax >= 150) {
      const lineY = 160 - (150 * 130 / yAxisMax);
      svg += `<line x1="45" y1="${lineY}" x2="590" y2="${lineY}" stroke="var(--red)" stroke-width="1.2" stroke-dasharray="4,3" opacity="0.8" />`;
      svg += `<text x="50" y="${lineY - 4}" fill="var(--red)" font-family="var(--sans)" font-size="8px" font-weight="700">Product A Hourly Cap (150 MWh)</text>`;
    }

    // Bars
    for (let h = 0; h < 24; h++) {
      const a = loc.profileA[h];
      const b = loc.profileB[h];
      
      const heightA = (a * 130) / yAxisMax;
      const heightB = (b * 130) / yAxisMax;
      
      const x = 50 + h * 22;
      const yA = 160 - heightA;
      const yB = 160 - heightA - heightB;
      
      // Rect Product A
      svg += `<rect x="${x}" y="${yA}" width="16" height="${heightA}" fill="var(--green)" opacity="0.85" rx="1">
        <title>HE ${h + 1} - Product A: ${a} MWh</title>
      </rect>`;
      
      // Rect Product B
      if (b > 0) {
        svg += `<rect x="${x}" y="${yB}" width="16" height="${heightB}" fill="var(--blue)" opacity="0.85" rx="1">
          <title>HE ${h + 1} - Product B: ${b} MWh</title>
        </rect>`;
      }

      // X Axis label
      if ((h + 1) % 2 === 0) {
        svg += `<text x="${x + 8}" y="178" fill="var(--ink-dim)" font-family="var(--sans)" font-size="8px" text-anchor="middle">HE ${h + 1}</text>`;
      }
    }

    // Baseline
    svg += `<line x1="45" y1="160" x2="590" y2="160" stroke="var(--border-light)" stroke-width="1.5" />`;
    svg += `</svg>`;

    svgContainer.innerHTML = svg;
  }

