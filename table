      if (!profile || profile.length === 0) return '';
      const mx = maxVal || Math.max(...profile, 1);
      let bars = '';
      const barW = (w / profile.length) * 0.7;
      const gap = (w / profile.length) * 0.3;
      profile.forEach((v, i) => {
        const bh = (v / mx) * (h - 14);
        const x = i * (barW + gap);
        const y = h - bh - 2;
        bars += `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${barW.toFixed(1)}" height="${bh.toFixed(1)}" fill="${color}" opacity="0.85" rx="0.5"/>`;
      });
      return `<svg viewBox="0 0 ${w} ${h}" style="width:${w}px;height:${h}px;display:block;overflow:visible;">
