        if (p.id === "PUR-AMZ-PJM-01") {
          p.mw = 20; // Original is 25, creating a 5 MW discrepancy (Short)
        }
        if (p.id === "PUR-AMZ-NP15-01") {
          p.mw = p.mw + 15; // Increase NP15 purchase by 15 MW (Long)
        }
      });
    }

    // 5. Plan Sale Deals (respecting Product A/B split totals)
    const totalA = Math.round(sortedLocations.reduce((sum, l) => sum + l.allocA, 0) * 10) / 10;
    const totalB = Math.round(sortedLocations.reduce((sum, l) => sum + l.allocB, 0) * 10) / 10;

    STATE.saleDeals = [
      { 
        id: "SAL-AMZ-A", 
        deal_num: "P-10300001",
        book: "WEST BOOKS/BRTM-WC-FII",
        deal_type: "Index",
        transaction_type: "Firm LD",
        counterparty: "AMAZON ENERGY SERVICES",
        market: "BPAT",
        zone: "MID-C",
        contract: "C20221028-PPA-BI",
        product: "Product A (Firm)", 
        term: "PRESCH",
        mw: totalA, 
        status: STATE.committed ? "Committed" : "Pending" 
      },
      { 
        id: "SAL-AMZ-B", 
        deal_num: "P-10300002",
        book: "WEST BOOKS/BRTM-WC-FII",
        deal_type: "Index",
        transaction_type: "Firm LD",
        counterparty: "AMAZON ENERGY SERVICES",
        market: "BPAT",
        zone: "MID-C",
        contract: "C20221028-PPA-BI",
        product: "Product B (Variable)", 
        term: "PRESCH",
        mw: totalB, 
        status: STATE.committed ? "Committed" : "Pending" 
      }
    ];

    // 6. Aggregate HE 1-24 Profiles for Product A and Product B
    STATE.hourlyProfileA = Array(24).fill(0);
    STATE.hourlyProfileB = Array(24).fill(0);
    sortedLocations.forEach(loc => {
      for (let h = 0; h < 24; h++) {
        STATE.hourlyProfileA[h] += loc.profileA[h];
        STATE.hourlyProfileB[h] += loc.profileB[h];
      }
    });
    for (let h = 0; h < 24; h++) {
      STATE.hourlyProfileA[h] = Math.round(STATE.hourlyProfileA[h] * 10) / 10;
      STATE.hourlyProfileB[h] = Math.round(STATE.hourlyProfileB[h] * 10) / 10;
    }

    // Always default to the highest-volume (first sorted) location
    if (!STATE._locInitialized || !sortedLocations.some(l => l.name === STATE.selectedLocName)) {
      STATE.selectedLocName = sortedLocations[0]?.name || STATE.selectedLocName;
      STATE._locInitialized = true;
    }

    // 7. Build Deal Schedules (One Tag per Schedule)
    const schedules = [];
    STATE.tags.forEach((tag, index) => {
      const schId = `SCH-AMZ-${tag.id.replace('TAG-AMZ-', '')}`;
      
      const loc = sortedLocations.find(l => l.name === tag.location);
      const ratio = loc.totalMW > 0 ? tag.mw / loc.totalMW : 0;
      
      // Calculate allocation A and B for this specific tag proportionally
      const tagAllocA = Math.round(loc.allocA * ratio * 10) / 10;
      const tagAllocB = Math.round((tag.mw - tagAllocA) * 10) / 10;
      
      const tagPurchases = purchases.filter(p => p.tag_id === tag.id);
      const locSales = [];
      
      if (tagAllocA > 0) {
        locSales.push({ deal_id: "SAL-AMZ-A", mw: tagAllocA });
      }
      if (tagAllocB > 0) {
        locSales.push({ deal_id: "SAL-AMZ-B", mw: tagAllocB });
      }

      // Proportional hourly profiles
      const tagProfileTotal = loc.profileTotal.map(val => Math.round(val * ratio * 10) / 10);
      const tagProfileA = loc.profileA.map(val => Math.round(val * ratio * 10) / 10);
      const tagProfileB = loc.profileB.map(val => Math.round(val * ratio * 10) / 10);

      schedules.push({
        id: schId,
        schedule_num: tag.schedule_num,
        tag_code: tag.tag_code,
        source: tag.source,
        sink: tag.sink,
        por: tag.por,
        pod: tag.pod,
        cpse: tag.cpse,
        location: tag.location,
        total_mw: tag.mw,
        tag_ids: [tag.id], // exactly one tag
        purchase_deal_ids: tagPurchases.map(p => p.id),
        sale_deals: locSales,
        profile: tagProfileTotal,
        profileA: tagProfileA,
        profileB: tagProfileB,
        status: STATE.committed ? "Committed" : "Pending"
      });
    });
    STATE.schedules = schedules;

    // Ensure selected schedule ID still exists, fallback if necessary
    if (schedules.length > 0 && !schedules.some(s => s.id === STATE.selectedScheduleId)) {
      STATE.selectedScheduleId = schedules[0].id;
    }

    // Validate balance checks
    const tagsMW = STATE.tags.reduce((sum, t) => sum + t.mw, 0);
    const purchMW = purchases.reduce((sum, p) => sum + p.mw, 0);
    const salesMW = STATE.saleDeals.reduce((sum, s) => sum + s.mw, 0);
    
    // Validate individual location audits
    let hasAuditFailure = false;
    if (STATE.locations) {
      STATE.locations.forEach(loc => {
        const locPurch = purchases.filter(p => p.location === loc.name);
        const purchSum = locPurch.reduce((sum, p) => sum + p.mw, 0);
        const diff = Math.abs(loc.totalMW - purchSum);
        const isRejected = STATE.locationStates[loc.name] === 'Rejected';
        if (isRejected) {
          hasAuditFailure = true;
        }
      });
    }

    const uncommittedTagsMW = STATE.tags.filter(t => t.status !== "Committed").reduce((sum, t) => sum + t.mw, 0);

    STATE.balanceStats = {
      tags_mw: Math.round(tagsMW * 10) / 10,
      uncommitted_tags_mw: Math.round(uncommittedTagsMW * 10) / 10,
      purchases_mw: Math.round(purchMW * 10) / 10,
      sales_mw: Math.round(salesMW * 10) / 10,
      balanced: Math.abs(tagsMW - purchMW) < 0.1 && Math.abs(purchMW - salesMW) < 0.1 && !hasAuditFailure,
      hasAuditFailure: hasAuditFailure
    };
  }

