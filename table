  function renderSourceClearanceChart(loc) {
    const container = document.getElementById("clearance-chart-container");
    if (!container) return;

    // 1. Prepare profiles
    const profile = loc.profileTotal;
    const purchasesTotal = Array(24).fill(0);
    const locPurchases = STATE.purchaseDeals.filter(p => p.location === loc.name);
    locPurchases.forEach(p => {
      const linkedTag = STATE.tags.find(t => t.id === p.tag_id);
      const prof = getHourlyProfile(p.mw, linkedTag ? linkedTag._curve : 'baseload');
      for (let h = 0; h < 24; h++) {
        purchasesTotal[h] += prof[h];
      }
    });

    const salesTotal = Array(24).fill(0);
    for (let h = 0; h < 24; h++) {
      salesTotal[h] = loc.profileA[h] + loc.profileB[h]; // Sales are positive
    }

    const netTotal = Array(24).fill(0);
    for (let h = 0; h < 24; h++) {
      netTotal[h] = Math.round((salesTotal[h] - purchasesTotal[h]) * 10) / 10; // Sales(+) - Purchases(-)
    }

    // 2. Grid scale range (Enforce minimum 150 MW so cap line is visible)
    const maxVal = Math.max(...profile, ...purchasesTotal, ...salesTotal, 150);
    const yRangeMax = Math.ceil((maxVal * 1.15) / 10) * 10 || 180;

    const yZero = 100;
    const yScale = 75 / yRangeMax;
    const hourX = (h) => 50 + h * 37;

    let svg = `<svg viewBox="0 0 960 200" style="width:100%; height:100%; display:block;">`;

    // Horizontal Grid Lines
    const ticks = [yRangeMax, yRangeMax * 0.5, 0, -yRangeMax * 0.5, -yRangeMax];
    ticks.forEach(tick => {
      const rounded = Math.round(tick * 10) / 10;
      const y = yZero - (tick * yScale);
      svg += `<line x1="40" y1="${y}" x2="940" y2="${y}" stroke="var(--border-light)" stroke-width="${tick === 0 ? 1.5 : 1}" stroke-dasharray="${tick === 0 ? 'none' : '3,3'}" />`;
      svg += `<text x="10" y="${y + 3}" fill="var(--ink-dim)" font-family="var(--mono)" font-size="8px">${rounded}</text>`;
    });

    // 150MW dashed cap line
    const yCap = yZero - (150 * yScale);
    svg += `<line x1="40" y1="${yCap}" x2="940" y2="${yCap}" stroke="rgba(255,255,255,0.15)" stroke-width="1.2" stroke-dasharray="3,3" />`;
    svg += `<text x="45" y="${yCap - 4}" fill="rgba(255,255,255,0.3)" font-family="var(--sans)" font-size="8px" font-weight="600">150 MW CAP</text>`;

    // Vertical columns, grid lines & Warning overlays
    for (let h = 0; h < 24; h++) {
      const x = hourX(h);
      
      // Draw faint vertical hourly grid line at the center of the hour interval
      svg += `<line x1="${x + 13}" y1="15" x2="${x + 13}" y2="185" stroke="rgba(255, 255, 255, 0.08)" stroke-width="1" stroke-dasharray="1,4" />`;

      // Net stray warnings: Net > 0 (Short) is Red, Net < 0 (Long) is Amber
      if (netTotal[h] > 0.1) {
        svg += `<rect x="${x - 2}" y="15" width="30" height="170" fill="var(--red)" opacity="0.12" rx="2" />`;
      } else if (netTotal[h] < -0.1) {
        svg += `<rect x="${x - 2}" y="15" width="30" height="170" fill="var(--amber)" opacity="0.10" rx="2" />`;
      }

      // X-Axis hours labels
      svg += `<text x="${x + 13}" y="194" fill="var(--ink-dim)" font-family="var(--sans)" font-size="8px" text-anchor="middle">HE ${h + 1}</text>`;
    }

    // Baseline Area Chart (Aggregated Tag Profile)
    let areaPoints = [`50,${yZero}`];
    for (let h = 0; h < 24; h++) {
      areaPoints.push(`${hourX(h) + 13},${yZero - (profile[h] * yScale)}`);
    }
    areaPoints.push(`${hourX(23) + 13},${yZero}`);
    svg += `<polygon class="animated-fade" style="animation-delay: 0.1s;" points="${areaPoints.join(' ')}" fill="var(--green-glow)" stroke="var(--green)" stroke-dasharray="3,3" stroke-width="1.2" opacity="0.5" />`;

    // Overlay Purchases (Negative vertical bars going down)
    for (let h = 0; h < 24; h++) {
      const pVal = purchasesTotal[h];
      const hPurch = pVal * yScale;
      svg += `<rect class="animated-bar" style="animation-delay: ${h * 0.012}s;" x="${hourX(h)}" y="${yZero}" width="26" height="${hPurch}" fill="var(--orange)" opacity="0.55" rx="1" />`;
    }

    // Overlay Sales (Positive vertical bars stacked going up)
    for (let h = 0; h < 24; h++) {
      const sValA = loc.profileA[h];
      const sValB = loc.profileB[h];
      const hSalesA = sValA * yScale;
      const hSalesB = sValB * yScale;
      
      svg += `<rect class="animated-bar" style="animation-delay: ${h * 0.012}s;" x="${hourX(h)}" y="${yZero - hSalesA}" width="26" height="${hSalesA}" fill="var(--green)" opacity="0.75" rx="1" />`;
      if (sValB > 0) {
        svg += `<rect class="animated-bar" style="animation-delay: ${h * 0.012}s;" x="${hourX(h)}" y="${yZero - hSalesA - hSalesB}" width="26" height="${hSalesB}" fill="var(--blue)" opacity="0.75" rx="1" />`;
      }
    }

    // Net Energy Line (Polyline)
    let netPoints = [];
    for (let h = 0; h < 24; h++) {
      netPoints.push(`${hourX(h) + 13},${yZero - (netTotal[h] * yScale)}`);
    }
    svg += `<polyline class="animated-net-line" style="animation-delay: 0.2s;" points="${netPoints.join(' ')}" fill="none" stroke="var(--cyan)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />`;

    // Circle dots and hourly MW labels on Net Energy Line
    for (let h = 0; h < 24; h++) {
      let dotColor = "var(--cyan)";
      if (netTotal[h] > 0.1) dotColor = "var(--red)";   // red (short)
      if (netTotal[h] < -0.1) dotColor = "var(--green)"; // green (long)
      
      const yDot = yZero - (netTotal[h] * yScale);
      svg += `<circle class="animated-fade" style="animation-delay: 1.0s;" cx="${hourX(h) + 13}" cy="${yDot}" r="3" fill="${dotColor}" stroke="#060608" stroke-width="1.2" />`;

      // Hourly data label for Net Energy MW (only show when there is a mismatch, hiding the green zeros)
      if (Math.abs(netTotal[h]) > 0.05) {
        const netLabelText = netTotal[h] > 0 ? `+${netTotal[h].toFixed(1)}` : `${netTotal[h].toFixed(1)}`;
        const textY = (yDot < 35) ? yDot + 12 : yDot - 8;
        svg += `<text class="animated-fade" style="animation-delay: 1.1s;" x="${hourX(h) + 13}" y="${textY}" fill="${dotColor}" font-family="var(--mono)" font-size="7.5px" font-weight="600" text-anchor="middle">${netLabelText}</text>`;
      }
    }

    // Hover rects for interactive tooltips
    for (let h = 0; h < 24; h++) {
      svg += `<rect x="${hourX(h) - 2}" y="15" width="30" height="170" fill="transparent" style="cursor:crosshair;" onmousemove="showClearanceTooltip(event, ${h}, ${profile[h]}, ${purchasesTotal[h]}, ${salesTotal[h]}, ${netTotal[h]})" onmouseout="hideClearanceTooltip()" />`;
    }

    svg += `</svg>`;

    const tooltip = document.getElementById("clearance-tooltip");
    container.innerHTML = "";
    container.appendChild(tooltip);
    container.insertAdjacentHTML("beforeend", svg);
  }

