  function getFlowTooltipSparkline(profile, color) {
    const max = Math.max(...profile, 1);
    const min = Math.min(...profile, 0);
    const range = max - min || 1;
    
    const svgWidth = 190;
    const svgHeight = 40;
    const topPadding = 4;
    const bottomPadding = 4;
    const plotHeight = svgHeight - topPadding - bottomPadding; // 32px
    
    // Zero line calculation
    const zeroY = svgHeight - bottomPadding - ((0 - min) * plotHeight) / range;
    
    let bars = [];
    const barWidth = 5;
    const gap = 2.0;
    const startX = (svgWidth - (24 * barWidth + 23 * gap)) / 2; // Center the bars
    
    for (let i = 0; i < 24; i++) {
      const val = profile[i];
      const valY = svgHeight - bottomPadding - ((val - min) * plotHeight) / range;
      
      let y, height;
      if (val >= 0) {
        y = valY;
        height = zeroY - valY;
      } else {
        y = zeroY;
        height = valY - zeroY;
      }
      
      // Make sure height is at least 1px if val > 0, so it's visible
      if (val > 0 && height < 1) height = 1;
      if (val < 0 && height < 1) height = 1;
      
      const x = startX + i * (barWidth + gap);
      bars.push(`<rect x="${x}" y="${y}" width="${barWidth}" height="${height}" fill="${color}" rx="1" />`);
    }
    
    let refLine = "";
    if (min < 0) {
      refLine = `<line x1="5" y1="${zeroY}" x2="${svgWidth - 5}" y2="${zeroY}" stroke="rgba(255,255,255,0.1)" stroke-width="1" stroke-dasharray="2,2" />`;
    }
    
    return `<svg width="${svgWidth}" height="${svgHeight}" style="overflow:visible; display:block; margin: 4px auto 0 auto; background: rgba(0,0,0,0.25); border-radius: 4px;">
      ${refLine}
      ${bars.join('\n')}
    </svg>`;
  }
