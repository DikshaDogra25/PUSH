  // CALENDAR DATE PICKER LOGIC
  // =========================================================================
  let selectedDate = new Date(2026, 5, 21); // June 21, 2026
  let currentCalendarDate = new Date(2026, 5, 21);

  function formatDate(date) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }

  function getFriendlyDateLabel(dateStr) {
    if (dateStr === "2026-06-21") return "2026-06-21 (Yesterday)";
    if (dateStr === "2026-06-22") return "2026-06-22 (Today)";
    return dateStr;
  }

  function toggleCalendarPopover() {
    const popover = document.getElementById("calendar-popover");
    if (!popover) return;
    if (popover.style.display === "block") {
      popover.style.display = "none";
    } else {
      popover.style.display = "block";
      currentCalendarDate = new Date(selectedDate);
      renderCalendar();
    }
  }

  function renderCalendar() {
    const monthYearEl = document.getElementById("calendar-month-year");
    const gridEl = document.getElementById("calendar-days-grid");
    if (!monthYearEl || !gridEl) return;

    const year = currentCalendarDate.getFullYear();
    const month = currentCalendarDate.getMonth();

    const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
    monthYearEl.innerText = `${months[month]} ${year}`;

    gridEl.innerHTML = "";

    // First day of the month
    const firstDay = new Date(year, month, 1).getDay();
    const numDays = new Date(year, month + 1, 0).getDate();

    // Padding cells before first day
    for (let i = 0; i < firstDay; i++) {
      gridEl.innerHTML += `<div class="calendar-day-cell empty-cell"></div>`;
    }

    const todayStr = "2026-06-22";
    const selectedStr = formatDate(selectedDate);

    for (let day = 1; day <= numDays; day++) {
      const cellDate = new Date(year, month, day);
      const cellDateStr = formatDate(cellDate);
      const isSelected = selectedStr === cellDateStr;
      const isToday = cellDateStr === todayStr;

      let classes = "calendar-day-cell";
      if (isSelected) classes += " selected-day";
      if (isToday) classes += " today-cell";

      gridEl.innerHTML += `
        <div class="${classes}" onclick="handleCalendarDayClick(${year}, ${month}, ${day}, event)">
          ${day}
        </div>
      `;
    }
  }

  function handleCalendarDayClick(year, month, day, e) {
    e.stopPropagation();
    selectedDate = new Date(year, month, day);
    const dateStr = formatDate(selectedDate);

    // Update trigger text
    const textEl = document.getElementById("selected-date-text");
    if (textEl) textEl.innerText = getFriendlyDateLabel(dateStr);

    // Update e-tag start/end dates in STATE
    STATE.tags.forEach(tag => {
      tag.start = `${dateStr} 00:00`;
      tag.end = `${dateStr} 23:59`;
    });

    // Re-run allocation engine and re-render
    runAllocationEngine();
    renderAll();

    // Close calendar
    const popover = document.getElementById("calendar-popover");
    if (popover) popover.style.display = "none";
  }

  function selectQuickDate(label, e) {
    e.stopPropagation();
    if (label === 'yesterday') {
      selectedDate = new Date(2026, 5, 21);
    } else if (label === 'today') {
      selectedDate = new Date(2026, 5, 22);
    }
    const dateStr = formatDate(selectedDate);

    // Update trigger text
    const textEl = document.getElementById("selected-date-text");
    if (textEl) textEl.innerText = getFriendlyDateLabel(dateStr);

    // Update e-tag start/end dates in STATE
    STATE.tags.forEach(tag => {
      tag.start = `${dateStr} 00:00`;
      tag.end = `${dateStr} 23:59`;
    });

    // Re-run allocation engine and re-render
    runAllocationEngine();
    renderAll();

    // Close calendar
    const popover = document.getElementById("calendar-popover");
    if (popover) popover.style.display = "none";
  }

  function prevMonth(e) {
    e.stopPropagation();
    currentCalendarDate.setMonth(currentCalendarDate.getMonth() - 1);
    renderCalendar();
  }

  function nextMonth(e) {
    e.stopPropagation();
    currentCalendarDate.setMonth(currentCalendarDate.getMonth() + 1);
    renderCalendar();
  }

  // =========================================================================
