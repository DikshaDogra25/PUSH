def convert_to_table(result) -> str:
    tags = (result or {}).get("Unschedule Tags") or []
    if not tags:
        return ""
    tags_json = json.dumps(_map_tags(tags), allow_nan=False, ensure_ascii=False)   # JsonSerializer.Serialize(resData)
    html_data = _load_template().replace(TAGS_TOKEN, tags_json)                     # var htmlData = $@"<html>…{data}…</html>"
    encoded   = html.escape(html_data, quote=True)                                  # WebUtility.HtmlEncode(htmlData)
    iframe    = f"<iframe width='100%' height='800' srcdoc=\"{encoded}\"></iframe>" # $@"<iframe … srcdoc=""{encoded}""></iframe>"
    return iframe.replace("\r\n", "")                                              # html.Replace("\r\n","")
