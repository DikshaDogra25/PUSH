    document.getElementById("wf-step4-mw").innerText = `${totalB.toFixed(1)} MWh`;
    document.getElementById("wf-step5-sales-count").innerText = `${STATE.saleDeals.length} deals`;
    document.getElementById("wf-step6-status").innerText = STATE.committed ? "Committed" : "Ready to Commit";
    document.getElementById("wf-step6-status").style.color = STATE.committed ? "var(--green)" : "var(--cyan)";

    // Shares bar overview
    const shareAPct = STATE.balanceStats.tags_mw > 0 ? Math.round((totalA / STATE.balanceStats.tags_mw) * 100) : 0;
    const shareBPct = STATE.balanceStats.tags_mw > 0 ? Math.round((totalB / STATE.balanceStats.tags_mw) * 100) : 0;
    document.getElementById("lbl-a-share").innerText = `${shareAPct}%`;
    document.getElementById("lbl-b-share").innerText = `${shareBPct}%`;
    document.getElementById("bar-a-share").style.width = `${shareAPct}%`;
    document.getElementById("bar-b-share").style.width = `${shareBPct}%`;

    // Overview balancing check labels
    document.getElementById("chk-tags-purchases").innerText = `${STATE.balanceStats.tags_mw.toFixed(1)} MWh / ${STATE.balanceStats.purchases_mw.toFixed(1)} MWh`;
    document.getElementById("chk-alloc-sales").innerText = `${STATE.balanceStats.tags_mw.toFixed(1)} MWh / ${STATE.balanceStats.sales_mw.toFixed(1)} MWh`;
    
    if (STATE.balanceStats.tags_mw !== STATE.balanceStats.purchases_mw) {
      document.getElementById("chk-tags-purchases").style.color = "var(--red)";
    } else {
      document.getElementById("chk-tags-purchases").style.color = "var(--green)";
    }
    if (STATE.balanceStats.tags_mw !== STATE.balanceStats.sales_mw) {
      document.getElementById("chk-alloc-sales").style.color = "var(--red)";
    } else {
      document.getElementById("chk-alloc-sales").style.color = "var(--green)";
    }

    // Dynamic Filter select update for tags
    const locFilter = document.getElementById("tag-loc-filter");
    const currentLocSel = locFilter.value;
    locFilter.innerHTML = `<option value="ALL">All Locations</option>`;
    STATE.locations.forEach(loc => {
      locFilter.innerHTML += `<option value="${loc.name}">${loc.name} (${loc.totalMW} MWh)</option>`;
    });
    locFilter.value = currentLocSel;

    // Dynamic Filter select update for purchases
    const purchFilter = document.getElementById("purch-loc-filter");
    if (purchFilter) {
      const currentPurchSel = purchFilter.value;
      purchFilter.innerHTML = `<option value="ALL">All Locations</option>`;
      STATE.locations.forEach(loc => {
        purchFilter.innerHTML += `<option value="${loc.name}">${loc.name} (${loc.totalMW} MWh)</option>`;
      });
      purchFilter.value = currentPurchSel;
    }

    // Badges counters on tabs
    document.getElementById("badge-tags-count").innerText = STATE.tags.filter(t => t.status !== "Committed").length;
    document.getElementById("badge-purchases-count").innerText = STATE.purchaseDeals.length;
    document.getElementById("badge-schedules-count").innerText = STATE.schedules.length;

    // Tab content components
    renderOverviewTab();
    renderTagsTable();
    renderPurchasesTable();
    renderLocationsTab();
    renderSchedulesTab();

    lucide.createIcons();
    renderKpiCharts();
  }

  // Draw 24-Hour Spark-Bar SVGs inside executive KPI cards
  function renderKpiCharts() {
    // 1. Unscheduled Tags Chart (stacked representation: orange if uncommitted, teal if committed)
    const tagProfile = Array(24).fill(0);
    STATE.tags.forEach(t => {
      const tProfile = getHourlyProfile(t.mw, t._curve || t.shape);
      for (let h = 0; h < 24; h++) {
        tagProfile[h] += tProfile[h];
      }
    });
    const maxTag = Math.max(...tagProfile, 1);
    const tagsContainer = document.getElementById("kpi-tags-chart-container");
    if (tagsContainer) {
      let svg = `<svg viewBox="0 0 110 45" preserveAspectRatio="none" style="width:100%; height:45px; display:block;">`;
      for (let h = 0; h < 24; h++) {
        let committedVal = 0;
        let uncommittedVal = 0;
        STATE.tags.forEach(t => {
          const tp = getHourlyProfile(t.mw, t._curve || t.shape);
          if (t.status === 'Committed') {
            committedVal += tp[h];
          } else {
            uncommittedVal += tp[h];
          }
        });
        const committedHeight = (committedVal / maxTag) * 38;
        const uncommittedHeight = (uncommittedVal / maxTag) * 38;
        const x = h * 4.5;
        const yComm = 42 - committedHeight;
        const yUncomm = 42 - committedHeight - uncommittedHeight;
        if (committedHeight > 0) {
          svg += `<rect x="${x}" y="${yComm}" width="3.2" height="${committedHeight}" fill="var(--green)" rx="0.5" opacity="0.95" />`;
        }
        if (uncommittedHeight > 0) {
          svg += `<rect x="${x}" y="${yUncomm}" width="3.2" height="${uncommittedHeight}" fill="var(--orange)" rx="0.5" opacity="0.95" />`;
        }
      }
      svg += `<text x="1" y="7" class="kpi-scale-label" fill="var(--ink-dim)" font-family="var(--mono)" font-size="5.5" font-weight="600">${Math.round(maxTag)}</text>`;
      svg += `<text x="1" y="44" class="kpi-scale-label" fill="var(--ink-dim)" font-family="var(--mono)" font-size="5.5" font-weight="600">0</text>`;
      svg += `</svg>`;
      tagsContainer.innerHTML = svg;
    }

    // 2. Product A Chart (Neon Teal) � exclude rejected locations
    const profileA = Array(24).fill(0);
    STATE.locations.forEach(loc => {
      if (getLocationState(loc.name) === 'Rejected') return;
      for (let h = 0; h < 24; h++) {
        profileA[h] += loc.profileA[h];
      }
    });
    const maxA = Math.max(...profileA, 1);
    const aContainer = document.getElementById("kpi-a-chart-container");
    if (aContainer) {
      let svg = `<svg viewBox="0 0 110 45" preserveAspectRatio="none" style="width:100%; height:45px; display:block;">`;
      for (let h = 0; h < 24; h++) {
        const val = profileA[h];
        const barHeight = (val / maxA) * 38;
        const x = h * 4.5;
        const y = 42 - barHeight;
        svg += `<rect x="${x}" y="${y}" width="3.2" height="${barHeight}" fill="var(--green)" rx="0.5" opacity="0.95" />`;
      }
      svg += `<text x="1" y="7" class="kpi-scale-label" fill="var(--ink-dim)" font-family="var(--mono)" font-size="5.5" font-weight="600">150</text>`;
      svg += `<text x="1" y="44" class="kpi-scale-label" fill="var(--ink-dim)" font-family="var(--mono)" font-size="5.5" font-weight="600">0</text>`;
      svg += `</svg>`;
      aContainer.innerHTML = svg;
    }

    // 3. Product B Chart (Blue) � exclude rejected locations
    const profileB = Array(24).fill(0);
    STATE.locations.forEach(loc => {
      if (getLocationState(loc.name) === 'Rejected') return;
      for (let h = 0; h < 24; h++) {
        profileB[h] += loc.profileB[h];
      }
    });
    const maxB = Math.max(...profileB, 1);
    const bContainer = document.getElementById("kpi-b-chart-container");
    if (bContainer) {
      let svg = `<svg viewBox="0 0 110 45" preserveAspectRatio="none" style="width:100%; height:45px; display:block;">`;
      for (let h = 0; h < 24; h++) {
        const val = profileB[h];
        const barHeight = (val / maxB) * 38;
        const x = h * 4.5;
        const y = 42 - barHeight;
        svg += `<rect x="${x}" y="${y}" width="3.2" height="${barHeight}" fill="var(--blue)" rx="0.5" opacity="0.95" />`;
      }
      svg += `<text x="1" y="7" class="kpi-scale-label" fill="var(--ink-dim)" font-family="var(--mono)" font-size="5.5" font-weight="600">${Math.round(maxB)}</text>`;
      svg += `<text x="1" y="44" class="kpi-scale-label" fill="var(--ink-dim)" font-family="var(--mono)" font-size="5.5" font-weight="600">0</text>`;
      svg += `</svg>`;
      bContainer.innerHTML = svg;
    }
  }

  // Toggle visual vs tabular panels
  function toggleCardFlip(cardId) {
    const current = flipStates[cardId] || "visual";
    const next = current === "visual" ? "tabular" : "visual";
    flipStates[cardId] = next;
    
    const visDiv = document.getElementById(`${cardId}-visual`);
    const tabDiv = document.getElementById(`${cardId}-tabular`);
    const btn = document.querySelector(`#${cardId} .btn-action`);

    if (next === "tabular") {
      visDiv.style.display = "none";
      visDiv.style.display = "none";
      tabDiv.style.display = "block";
      btn.innerHTML = `<i data-lucide="image" style="width:13px; height:13px;"></i>`;
      btn.title = "Show Visual";
    } else {
      visDiv.style.display = "block";
      tabDiv.style.display = "none";
      btn.innerHTML = `<i data-lucide="table" style="width:13px; height:13px;"></i>`;
      btn.title = "Show Tabular";
    }
    lucide.createIcons();
  }

  // Select Location Profile and refresh Tab 3 elements
  function selectLocationProfile(locName) {
    STATE.selectedLocName = locName;
    renderLocationsTab();
    lucide.createIcons();
  }

  function renderTagsTable() {
    const query = document.getElementById("tag-search").value.toLowerCase();
    const locSel = document.getElementById("tag-loc-filter").value;
    const statusSel = STATE.tabFilters.tags;
    const tbody = document.querySelector("#tags-table tbody");
    if (!tbody) return;
    tbody.innerHTML = "";

    const tDraftCount = STATE.tags.filter(t => !t.status || t.status === "Unscheduled" || t.status === "Planned" || t.status === "Pending").length;
    const tAccCount = STATE.tags.filter(t => t.status === "Accepted").length;
    const tRejCount = STATE.tags.filter(t => t.status === "Rejected").length;
    const tCommCount = STATE.tags.filter(t => t.status === "Committed").length;
    renderTabFilterPills('tags-filter-pills', 'tags', [
      { key: 'All', label: 'All', count: STATE.tags.length },
      { key: 'Draft', label: 'Draft', count: tDraftCount },
      { key: 'Accepted', label: 'Accepted', count: tAccCount },
      { key: 'Rejected', label: 'Rejected', count: tRejCount },
      { key: 'Committed', label: 'Scheduled', count: tCommCount },
    ]);

    const filtered = STATE.tags.filter(t => {
      const matchQuery = t.tag_code.toLowerCase().includes(query) ||
                         t.schedule_num.toLowerCase().includes(query) ||
                         t.source.toLowerCase().includes(query) ||
                         t.sink.toLowerCase().includes(query) ||
                         t.por.toLowerCase().includes(query) ||
                         t.pod.toLowerCase().includes(query) ||
                         t.cpse.toLowerCase().includes(query) ||
                         t.location.toLowerCase().includes(query);
      const matchLoc = (locSel === "ALL") || (t.location === locSel);

      let matchStatus = true;
      if (statusSel !== "All") {
        if (statusSel === "Draft") {
          matchStatus = (!t.status || t.status === "Unscheduled" || t.status === "Planned" || t.status === "Pending");
        } else {
          matchStatus = (t.status === statusSel);
        }
      }
      return matchQuery && matchLoc && matchStatus;
    });

    filtered.forEach(t => {
      let statusBadge = `<span class="status-badge red">Unscheduled</span>`;
      if (t.status === "Planned" || t.status === "Pending") statusBadge = `<span class="status-badge amber">Pending</span>`;
      if (t.status === "Accepted") statusBadge = `<span class="status-badge green">Accepted</span>`;
      if (t.status === "Rejected") statusBadge = `<span class="status-badge red">Rejected</span>`;
      if (t.status === "Committed") statusBadge = `<span class="status-badge green">Scheduled</span>`;

      const baseSink = t.sink.split('_')[0];
      const pathStr = `${t.source} ? ${t.cpse} ? ${baseSink}`;

      const tr = document.createElement("tr");
      tr.className = "clickable";
      tr.onclick = () => openDrawer("Tag", t.id);
      tr.onmousemove = (e) => showFlowTooltip(e, "Tag", t.id, t.location);
      tr.onmouseout = () => hideFlowTooltip();
      tr.innerHTML = `
        <td style="font-family:var(--mono); font-weight:600; color:var(--ink-primary);">${t.tag_code}</td>
        <td style="font-family:var(--mono);">${t.schedule_num.replace(/^P-/, '')}</td>
        <td>${t.source} / ${t.sink}</td>
        <td>${t.por} / ${t.pod}</td>
        <td>${t.cpse}</td>
        <td style="font-family:var(--mono); font-weight:600;">${t.mw}</td>
        <td><span style="font-family:var(--mono); font-size:10px; color:var(--ink-secondary); font-weight:600;">${pathStr}</span></td>
        <td>${statusBadge}</td>
        <td>
          <i data-lucide="eye" style="color:var(--ink-dim); width:15px; height:15px;"></i>
        </td>
      `;
      tbody.appendChild(tr);
    });
  }

  // Render Tab 3: Locations Buckets, Profile and Contributing Tags list
  function renderLocationsTab() {
    const maxMW = STATE.locations[0]?.totalMW || 1;

    const lDraftCount = STATE.locations.filter(l => getLocationState(l.name) === 'Draft').length;
    const lAccCount = STATE.locations.filter(l => getLocationState(l.name) === 'Accepted').length;
    const lRejCount = STATE.locations.filter(l => getLocationState(l.name) === 'Rejected').length;
    const lCommCount = STATE.locations.filter(l => getLocationState(l.name) === 'Committed').length;
    renderTabFilterPills('locations-filter-pills', 'locations', [
      { key: 'All', label: 'All', count: STATE.locations.length },
      { key: 'Draft', label: 'Draft', count: lDraftCount },
      { key: 'Accepted', label: 'Accepted', count: lAccCount },
      { key: 'Rejected', label: 'Rejected', count: lRejCount },
      { key: 'Committed', label: 'Scheduled', count: lCommCount },
    ]);

    const locFilter = STATE.tabFilters.locations;
    const filteredLocations = locFilter === 'All'
      ? STATE.locations
      : STATE.locations.filter(loc => getLocationState(loc.name) === locFilter);

    // 1. Left Card: Location Buckets list
    const bucketsVisual = document.getElementById("card-loc-buckets-visual");
    if (bucketsVisual) {
      bucketsVisual.innerHTML = "";
    }

    const bucketsTabularBody = document.querySelector("#loc-buckets-table tbody");
    if (bucketsTabularBody) {
      bucketsTabularBody.innerHTML = "";
    }

    filteredLocations.forEach((loc, index) => {
      const pct = Math.round((loc.totalMW / maxMW) * 100);
      const activeClass = (loc.name === STATE.selectedLocName) ? "active" : "";
      
      // Calculate warning state
      const locPurch = STATE.purchaseDeals.filter(p => p.location === loc.name);
      const purchSum = locPurch.reduce((sum, p) => sum + p.mw, 0);
      const hasDiscrepancy = Math.abs(loc.totalMW - purchSum) > 0.1;
      const isRejected = STATE.locationStates[loc.name] === 'Rejected';
      const hasWarning = hasDiscrepancy || isRejected;
      
      let warnIcon = "";
      if (hasWarning) {
        const titleText = isRejected ? "Location Rejected" : `Audit Mismatch: Purchases (${purchSum.toFixed(1)} MWh) do not match Tags (${loc.totalMW.toFixed(1)} MWh)`;
        warnIcon = `<i data-lucide="alert-triangle" style="color:var(--red); width:13px; height:13px; display:inline-block; vertical-align:middle; margin-left:6px;" title="${titleText}"></i>`;
      }
      
      // Get dynamic location status
      const lState = getLocationState(loc.name);
      let locStateBadge = `<span class="status-badge slate" style="font-size:8px; padding:1px 6px;">Draft</span>`;
      if (lState === 'Accepted') {
        locStateBadge = `<span class="status-badge green" style="font-size:8px; padding:1px 6px;">Accepted</span>`;
      } else if (lState === 'Rejected') {
        locStateBadge = `<span class="status-badge red" style="font-size:8px; padding:1px 6px;">Rejected</span>`;
      } else if (lState === 'Committed') {
        locStateBadge = `<span class="status-badge green" style="font-size:8px; padding:1px 6px; border: 1px solid var(--green);">Scheduled</span>`;
      }
      
      const tagCount = STATE.tags.filter(t => t.location === loc.name).length;
      const aPct = loc.totalMW > 0 ? Math.round((loc.allocA / loc.totalMW) * 100) : 0;
      const bPct = 100 - aPct;
      const itemHTML = `
        <div class="horiz-rule-item clickable ${activeClass}" onclick="selectLocationProfile('${loc.name}')" style="padding: 7px 10px; gap: 0;">
          <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
            <span style="display:flex; align-items:center; gap:5px; min-width:0; flex:1;">
              <strong style="color:var(--cyan); font-family:var(--mono); font-size:9px; flex-shrink:0;">#${index + 1}</strong>
              <span style="font-size:11px; font-weight:600; color:var(--ink-primary); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${loc.name}</span>
              ${warnIcon}
            </span>
            <div style="display:flex; align-items:center; gap:6px; flex-shrink:0; margin-left:8px;">
              ${locStateBadge}
              <strong style="font-family:var(--mono); font-size:11px; color:var(--ink-primary);">${(loc.totalMW / 24).toFixed(1)}</strong>
            </div>
          </div>
          <div style="margin: 5px 0 3px; height:4px; background:rgba(255,255,255,0.04); border-radius:2px; width:100%; overflow:hidden; display:flex;">
            ${aPct > 0 ? `<div style="width:${aPct}%; background:var(--green); opacity:0.85;"></div>` : ''}
            ${bPct > 0 ? `<div style="width:${bPct}%; background:var(--blue); opacity:0.85;"></div>` : ''}
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; width:100%; font-size:9px; color:var(--ink-dim);">
            <span><span style="color:var(--green); font-weight:600;">A</span> ${loc.allocA.toFixed(0)} MW &nbsp;<span style="color:var(--blue); font-weight:600;">B</span> ${loc.allocB.toFixed(0)} MW</span>
            <span>${tagCount} tag${tagCount !== 1 ? 's' : ''}</span>
          </div>
        </div>
      `;
      if (bucketsVisual) {
        bucketsVisual.insertAdjacentHTML("beforeend", itemHTML);
      }

      // Tabular Panel Row
      if (bucketsTabularBody) {
        bucketsTabularBody.innerHTML += `
          <tr class="clickable ${activeClass}" onclick="selectLocationProfile('${loc.name}')">
            <td><strong>#${index + 1}</strong></td>
            <td style="font-family:var(--brand); font-weight:600; color:var(--ink-primary); display: flex; align-items: center; justify-content: space-between; gap: 8px;">
              <span>${loc.name}${warnIcon}</span>
              ${locStateBadge}
            </td>
            <td style="font-family:var(--mono); color:var(--green); font-weight:600;">${loc.allocA.toFixed(1)}</td>
            <td style="font-family:var(--mono); color:var(--blue); font-weight:600;">${loc.allocB.toFixed(1)}</td>
            <td style="font-family:var(--mono); font-weight:600; color:var(--ink-primary);">${loc.totalMW.toFixed(1)}</td>
          </tr>
        `;
      }
    });

    // 2. Right Card: selected Location Product A & B Stacked Profile SVG
    const loc = STATE.locations.find(l => l.name === STATE.selectedLocName);
    if (loc) {
      const titleEl = document.getElementById("loc-profile-title-name");
      if (titleEl) titleEl.innerText = loc.name;
      
      renderLocProfileChartStacked(loc);
      renderLocProfileTableSplit(loc);
      renderLocContributingTagsTable(loc);
    }
  }
  function renderLocReconWireframe(loc) {
    const wireframeContainer = document.getElementById("loc-flow-wireframe-container");
    if (!wireframeContainer) return;

    const locTags = STATE.tags.filter(t => t.location === loc.name);
    if (locTags.length === 0) {
      wireframeContainer.innerHTML = '<div style="color:var(--ink-dim); text-align:center; padding:20px; font-size:11px; font-style:italic;">No tags for this location.</div>';
      return;
    }

    // Ensure a valid selected tag for this location
    if (!STATE.selectedTagByLoc[loc.name] || !locTags.find(t => t.tag_code === STATE.selectedTagByLoc[loc.name])) {
      STATE.selectedTagByLoc[loc.name] = locTags[0].tag_code;
    }
    const selectedTagCode = STATE.selectedTagByLoc[loc.name];
    const selectedTag = locTags.find(t => t.tag_code === selectedTagCode) || locTags[0];

    // Populate schedule tabs in card header
    const schedTabsEl = document.getElementById("overview-schedule-tabs");
    if (schedTabsEl) {
      if (locTags.length > 1) {
        schedTabsEl.style.display = "flex";
        schedTabsEl.innerHTML = locTags.map(tag => {
          const isActive = tag.tag_code === selectedTag.tag_code;
          return `<button onclick="selectOverviewTag('${loc.name}', '${tag.tag_code}')"
            style="padding:3px 12px; font-size:10px; font-family:var(--mono); font-weight:700;
              background:${isActive ? 'rgba(6,182,212,0.1)' : 'rgba(255,255,255,0.01)'};
              border:1px solid ${isActive ? 'var(--cyan)' : 'var(--border-light)'};
              border-bottom: ${isActive ? '2px solid var(--cyan)' : '1px solid var(--border-light)'};
              border-radius:4px 4px 0 0; color:${isActive ? 'var(--cyan)' : 'var(--ink-dim)'};
              cursor:pointer; transition:var(--transition); letter-spacing:0.03em;">${tag.tag_code}</button>`;
        }).join('');
      } else {
        schedTabsEl.style.display = "none";
        schedTabsEl.innerHTML = "";
      }
    }

    wireframeContainer.innerHTML = buildTagWireframeHTML(selectedTag, loc);

    if (window.lucide) lucide.createIcons();
  }

  function buildTagWireframeHTML(tag, loc) {
    // Tag row
    const tagHTML = `
      <div class="wireframe-row-item" style="cursor:pointer;" onmousemove="showFlowTooltip(event,'Tag','${tag.id}','${loc.name}')" onmouseout="hideFlowTooltip()">
        <span style="font-family:var(--mono); font-weight:600; color:var(--ink-primary); font-size:10.5px; display:flex; align-items:center; gap:4px;">
          <i data-lucide="tag" style="width:10px; height:10px; color:var(--green);"></i> ${tag.tag_code}
        </span>
        <span style="font-family:var(--mono); font-weight:700; color:var(--green); font-size:10.5px;">${tag.mw.toFixed(1)} MWh</span>
      </div>`;

    // Purchases for this specific tag
    const tagPurchases = STATE.purchaseDeals.filter(p => p.tag_id === tag.id);
    let purchasesHTML = '';
    if (tagPurchases.length === 0) {
      purchasesHTML = `<div style="color:var(--ink-dim); font-size:9.5px; text-align:center; font-style:italic; padding:4px 0;">No Purchase Deals</div>`;
    } else {
      tagPurchases.forEach(p => {
        const prodText = tag.product === 'A' ? 'ACS Energy' : tag.product === 'B' ? 'Carbon Free' : 'ACS & Carbon Free';
        purchasesHTML += `
          <div class="wireframe-row-item" style="cursor:pointer; display:flex; flex-direction:column; align-items:flex-start; padding:4px 6px;" onmousemove="showFlowTooltip(event,'PurchaseDeal','${p.id}','${loc.name}')" onmouseout="hideFlowTooltip()">
            <div style="display:flex; justify-content:space-between; width:100%; align-items:center;">
              <span style="font-family:var(--mono); font-weight:600; color:var(--ink-primary); font-size:10px; display:flex; align-items:center; gap:4px;">
                <i data-lucide="shopping-bag" style="width:10px; height:10px; color:var(--ink-dim);"></i> ${p.deal_num.replace(/^P-/, '')}
              </span>
              <span style="font-family:var(--mono); font-weight:700; color:var(--orange); font-size:10px;">-${p.mw.toFixed(1)} MWh</span>
            </div>
            <div style="font-size:7.5px; color:var(--ink-dim); margin-top:1.5px; padding-left:14px; font-weight:500;">Product: ${prodText}</div>
          </div>`;
      });
    }
    const purchasesTotalSum = tagPurchases.reduce((sum, p) => sum + p.mw, 0);

    // Sales from this tag's schedule
    const tagSchedule = STATE.schedules.find(s => s.tag_code === tag.tag_code);
    let salesHTML = '';
    let salesTotalSum = 0;
    if (tagSchedule && tagSchedule.sale_deals.length > 0) {
      tagSchedule.sale_deals.forEach(sd => {
        const deal = STATE.saleDeals.find(s => s.id === sd.deal_id);
        if (!deal) return;
        const isA = sd.deal_id === 'SAL-AMZ-A';
        const color = isA ? 'var(--green)' : 'var(--blue)';
        const iconName = isA ? 'zap' : 'activity';
        const prodLabel = isA ? 'ACS Energy' : 'Carbon Free';
        salesHTML += `
          <div class="wireframe-row-item" style="cursor:pointer; display:flex; flex-direction:column; align-items:flex-start; padding:4px 6px;" onmousemove="showFlowTooltip(event,'SaleDeal','${deal.id}','${loc.name}')" onmouseout="hideFlowTooltip()">
            <div style="display:flex; justify-content:space-between; width:100%; align-items:center;">
              <span style="font-family:var(--sans); font-weight:600; color:var(--ink-primary); font-size:10px; display:flex; align-items:center; gap:4px;">
                <i data-lucide="${iconName}" style="width:10px; height:10px; color:${color};"></i> ${deal.deal_num}
              </span>
              <span style="font-family:var(--mono); font-weight:700; color:${color}; font-size:10px;">+${sd.mw.toFixed(1)} MWh</span>
            </div>
            <div style="font-size:7.5px; color:var(--ink-dim); margin-top:1.5px; padding-left:14px; font-weight:500;">Product: ${prodLabel}</div>
          </div>`;
        salesTotalSum += sd.mw;
      });
    } else {
      salesHTML = `<div style="color:var(--ink-dim); font-size:9.5px; text-align:center; font-style:italic; padding:4px 0;">No Sale Deals</div>`;
    }

    // Schedule metadata
    const scheduleId = tagSchedule ? tagSchedule.id : `SCH-AMZ-${tag.id.replace('TAG-AMZ-', '')}`;
    const scheduleNum = tagSchedule ? tagSchedule.schedule_num : scheduleId;
    const locState = STATE.locationStates[loc.name] || 'Draft';
    const scheduleStatus = STATE.committed ? 'Scheduled' : (locState === 'Accepted' ? 'Accepted' : locState === 'Rejected' ? 'Rejected' : 'Pending');
    const statusColor = (scheduleStatus === 'Scheduled' || scheduleStatus === 'Accepted') ? 'var(--green)' : scheduleStatus === 'Rejected' ? 'var(--red)' : 'var(--cyan)';
    const netDiff = salesTotalSum - purchasesTotalSum;
    const netBalanced = Math.abs(netDiff) < 0.1;
    const scheduleStatusLabel = netBalanced
      ? `<span style="color:var(--green); font-size:8.5px; font-weight:700;">Fully Matched</span>`
      : `<span style="color:var(--red); font-size:8.5px; font-weight:700;">Mismatch: ${Math.abs(netDiff).toFixed(1)} MWh</span>`;

    return `
      <div style="display:flex; flex-direction:column; gap:6px; width:100%; min-width:440px; padding:4px 0;">
        <!-- E-Tag -->
        <div style="display:flex; justify-content:center; width:100%;">
          <div class="wireframe-card physical-etag" style="width:220px;">
            <div style="font-size:8.5px; text-transform:uppercase; font-weight:700; color:var(--green); text-align:center; border-bottom:1px solid rgba(20,153,116,0.15); padding-bottom:4px; margin-bottom:2px;">Physical E-Tag</div>
            <div style="display:flex; flex-direction:column; gap:4px;">${tagHTML}</div>
          </div>
