<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Amazon Schedule Planner - Automation &amp; Allocation Portal</title>
  
  <!-- Google Fonts: Outfit (Brand & Headings), Inter (UI Body), JetBrains Mono (Data tables) -->
  <link rel="preconnect" href="https://fonts.googleapis.com/">
  <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="">
  <link href="./Amazon Schedule Planner - Automation &amp; Allocation Portal_files/css2" rel="stylesheet">
  
  <!-- Lucide Icons CDN -->
  <script src="./Amazon Schedule Planner - Automation &amp; Allocation Portal_files/lucide@latest"></script>

  <style>
    /* =========================================================================
       SYSTEM VARIABLES & COLOR TOKENS (RED BRAND ACCENT & BLUE PRODUCT B ACCENT)
       ========================================================================= */
    :root {
      --bg: #060608;
      --surface: #0a0a0d;
      --surface-card: #101015;
      --surface-card-hover: #15151e;
      --surface-input: #050507;
      --border: rgba(6, 182, 212, 0.06);
      --border-light: rgba(255, 255, 255, 0.03);
      --border-hover: rgba(6, 182, 212, 0.16);
      --border-focus: var(--cyan);
      
      --cyan: #06b6d4; /* Vivid Cyan */
      --cyan-glow: rgba(6, 182, 212, 0.10);
      --cyan-deep: #0891b2;
      
      --ink-primary: #f1f5f9;
      --ink-secondary: #cbd5e1;
      --ink-dim: #8a99ad;
      --ink-muted: #3d4959;
      
      --purple: #b55fe6; /* Vivid Violet for net energy profile */
      --purple-glow: rgba(181, 95, 230, 0.10);
      --purple-deep: #4c1d69;
      
      --orange: #ffa854; /* Brighter/lighter Vivid Orange for purchases */
      --orange-glow: rgba(255, 168, 84, 0.12);
      --orange-deep: #9a3412;
      
      /* Colors */
      --red: #d6455b; /* Crimson Rose-Red */
      --red-glow: rgba(214, 69, 91, 0.10);
      --red-deep: #a21032;
      
      --blue: #ffb020; /* Vibrant Gold/Amber for Product B */
      --blue-glow: rgba(255, 176, 32, 0.08);
      --blue-deep: #613d00;
      
      --green: #149974; /* Emerald Green for Product A */
      --green-glow: rgba(20, 153, 116, 0.08);
      --green-deep: #053b2e;
      
      --amber: #cf8813; /* Muted Gold-Amber */
      --amber-glow: rgba(207, 136, 19, 0.08);
      --amber-deep: #5c3b07;
      
      --radius: 12px;
      --radius-sm: 8px;
      --radius-lg: 18px;
      
      --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.6);
      --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.8);
      --shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.95);
      --shadow-red-glow: 0 0 24px rgba(214, 69, 91, 0.04);
      --shadow-amber-glow: 0 0 24px rgba(207, 136, 19, 0.04);
      --shadow-glow: 0 0 20px rgba(255, 255, 255, 0.01);
      
      --sans: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --brand: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --mono: 'JetBrains Mono', ui-monospace, monospace;
      
      --transition: all 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg);
      background-image: 
        radial-gradient(1200px 900px at 0% 0%, rgba(6, 182, 212, 0.05), transparent 70%),
        radial-gradient(800px 600px at 100% 100%, rgba(68, 119, 210, 0.03), transparent 85%);
      background-attachment: fixed;
      font-family: var(--sans);
      color: var(--ink-primary);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
	line-height: 1.5;
      min-height: 100vh;
      overflow-x: auto;          /* allow horizontal scroll instead of clipping */
      overflow-y: auto;
      padding: 12px;             /* less padding so more room in a small window */
      display: flex;
      justify-content: center;
    }

    /* Scrollbars */
* {
      scrollbar-width: thin;                                  /* Firefox */
      scrollbar-color: #b8bcc4 rgba(255,255,255,0.05);        /* thumb, track (Firefox) */
    }
      ::-webkit-scrollbar {
      width: 12px;
      height: 12px;
    }
     ::-webkit-scrollbar-track {
      background: rgba(255,255,255,0.05);
      border-radius: 99px;
    }
      ::-webkit-scrollbar-thumb {
      background: #b8bcc4;                                     /* light grey */
      border-radius: 99px;
      border: 2px solid rgba(0,0,0,0.15);                     /* padding so it reads as a pill */
      background-clip: padding-box;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #d5d8de;                                    /* lighter on hover */
    }
	 ::-webkit-scrollbar-corner {
      background: rgba(255,255,255,0.05);
    }

    .dashboard-container {
      width: 100%;
      max-width: 1540px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
	
	/* Responsiveness for small / embedded chat windows */
    @media (max-width: 900px) {
      body { padding: 8px; }
      .dashboard-container { gap: 12px; }
      .kpi-strip, .ids { grid-template-columns: 1fr !important; }   /* stack KPI tiles */
      .dashboard-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
    }
	/* Overview row stacks on narrow / embedded windows */
    @media (max-width: 820px) {
      .overview-grid {
        grid-template-columns: 1fr !important;   /* stack the three columns */
      }
    }
    /* Wide inner tables/grids: let them scroll horizontally rather than overflow the frame */
    .table-container, .tabs-navigation { overflow-x: auto; }

    /* =========================================================================
       HEADER COMPONENT
       ========================================================================= */
    .dashboard-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 24px;
      background: var(--surface-card);
      border: 1px solid var(--border-light);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      flex-wrap: wrap;
      gap: 16px;
    }
    .brand-title-group {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .brand-logo {
      width: 40px;
      height: 40px;
      background: linear-gradient(135deg, var(--cyan) 0%, var(--cyan-deep) 100%);
      border-radius: 10px;
      display: grid;
      place-items: center;
      box-shadow: 0 4px 12px var(--cyan-glow);
    }
    .brand-logo svg {
      width: 22px;
      height: 22px;
      color: #fff;
    }
    .brand-text h1 {
      font-family: var(--brand);
      font-size: 20px;
      font-weight: 700;
      color: var(--ink-primary);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .brand-text h1 span.pill {
      background: var(--cyan-glow);
      color: var(--cyan);
      font-size: 10px;
      font-family: var(--sans);
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 99px;
      border: 1px solid rgba(6, 182, 212, 0.15);
      letter-spacing: 0.05em;
    }
    .brand-text p {
      font-size: 12px;
      color: var(--ink-dim);
      margin-top: 1px;
    }
    .filter-panel {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .filter-group {
      display: flex;
      align-items: center;
      background: var(--surface-input);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-sm);
      padding: 4px 12px;
      gap: 8px;
      transition: var(--transition);
    }
    .filter-group:hover, .filter-group:focus-within {
      border-color: var(--border-hover);
    }
    .filter-group label {
      font-size: 11px;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--ink-dim);
      letter-spacing: 0.05em;
    }
    .filter-select {
      background: transparent;
      border: none;
      color: var(--ink-primary);
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 600;
      outline: none;
      cursor: pointer;
      padding-right: 6px;
    }
    .filter-select option {
      background: var(--surface);
      color: var(--ink-primary);
    }
    
    /* Buttons */
    .btn-action {
      background: var(--surface-input);
      border: 1px solid var(--border-light);
      color: var(--ink-secondary);
      padding: 8px 16px;
      border-radius: var(--radius-sm);
      font-family: var(--brand);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: var(--transition);
      display: flex;
      align-items: center;
      gap: 6px;
      outline: none;
    }
    .btn-action:hover {
      border-color: var(--border-hover);
      color: var(--ink-primary);
      background: var(--surface-card);
    }
    .btn-primary {
      background: var(--cyan);
      border: 1px solid var(--cyan-deep);
      color: #fff;
    }
    .btn-primary:hover {
      background: var(--cyan-deep);
      box-shadow: 0 0 12px var(--cyan-glow);
      color: #fff;
    }

    /* =========================================================================
       EXECUTIVE SUMMARY STATS (TOP ROW KPI CARDS)
       ========================================================================= */
    .executive-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    
    @media (max-width: 1024px) {
      .executive-bar {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 640px) {
      .executive-bar {
        grid-template-columns: 1fr;
      }
    }

    .kpi-widget {
      background: var(--surface-card);
      border: 1px solid var(--border-light);
      border-radius: var(--radius);
      padding: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: var(--transition);
    }
    .kpi-widget:hover {
      border-color: var(--border-hover);
      transform: translateY(-2px);
      box-shadow: var(--shadow-md), var(--shadow-red-glow);
    }
    
    /* 2px left Indicator Bar */
    .kpi-widget::before {
      content: '';
      position: absolute;
      top: 0; left: 0; width: 2px; height: 100%;
      background: var(--ink-muted);
      transition: var(--transition);
    }
    .kpi-widget.ok::before { background: var(--green); }
    .kpi-widget.warn::before { background: var(--amber); }
    .kpi-widget.danger::before { background: var(--red); }
    .kpi-widget.blue::before { background: var(--blue); }
    
    /* KPI Metric Value text coloring */
    .kpi-widget.ok .kpi-value { color: var(--ink-primary); }
    .kpi-widget.warn .kpi-value { color: var(--amber); }
    .kpi-widget.danger .kpi-value { color: var(--red); }
    .kpi-widget.blue .kpi-value { color: var(--blue); }
    
    .kpi-details {
      display: flex;
      flex-direction: column;
      gap: 4px;
      z-index: 1;
    }
    .kpi-label {
      font-size: 11px;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--ink-dim);
      letter-spacing: 0.05em;
    }
    .kpi-value {
      font-family: var(--brand);
      font-size: 28px;
      font-weight: 800;
      color: var(--ink-primary);
      line-height: 1.1;
      display: flex;
      align-items: baseline;
      gap: 6px;
      transition: var(--transition);
    }
    .kpi-value .subtext {
      font-size: 13px;
      font-weight: 500;
      color: var(--ink-dim);
      font-family: var(--sans);
    }
    .kpi-sub {
      font-size: 9px;
      color: var(--ink-dim);
      font-weight: 500;
      font-family: var(--sans);
      line-height: 1.3;
    }

    .kpi-scale-label { display: none; }

    .kpi-icon-container {
      width: 48px;
      height: 48px;
      border-radius: 8px;
      background: transparent;
      border: none;
      display: grid;
      place-items: center;
      color: var(--ink-dim);
      position: relative;
      transition: var(--transition);
    }
    .kpi-icon-container.danger { color: var(--red); }
    .kpi-icon-container.danger svg { animation: pulse-red 2s infinite; }
    .kpi-icon-container.warn { color: var(--amber); }
    .kpi-icon-container.ok { color: var(--green); }
    .kpi-icon-container.blue { color: var(--blue); }

    @keyframes pulse-red {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.85; transform: scale(1.06); }
    }

    /* =========================================================================
       SECTION NAVIGATION PILLS (TABS)
       ========================================================================= */
    .tabs-navigation {
      display: flex;
      background: var(--surface-card);
      border: 1px solid var(--border-light);
      border-radius: var(--radius);
      padding: 6px;
      gap: 4px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      box-shadow: var(--shadow-sm);
    }
    .tabs-navigation::-webkit-scrollbar {
      display: none;
    }
    .tab-pill {
      background: transparent;
      border: none;
      color: var(--ink-dim);
      font-family: var(--brand);
      font-size: 13px;
      font-weight: 600;
      padding: 10px 18px;
      border-radius: var(--radius-sm);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
      transition: var(--transition);
      scroll-snap-align: start;
      outline: none;
    }
    .tab-pill:hover {
      color: var(--ink-primary);
      background: rgba(255, 255, 255, 0.02);
    }
    .tab-pill.active {
      background: rgba(6, 182, 212, 0.06);
      color: var(--cyan);
      border: 1px solid rgba(6, 182, 212, 0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
    }
    .tab-pill svg {
      width: 15px;
      height: 15px;
    }
    .tab-badge {
      background: rgba(255, 255, 255, 0.04);
      color: var(--ink-dim);
      font-family: var(--mono);
      font-size: 10.5px;
      font-weight: 600;
      padding: 1px 6px;
      border-radius: 99px;
      margin-left: 2px;
      display: inline-block;
      border: 1px solid rgba(255, 255, 255, 0.02);
      transition: var(--transition);
    }
    .tab-pill.active .tab-badge {
      background: rgba(6, 182, 212, 0.12);
      color: var(--cyan);
      border-color: rgba(6, 182, 212, 0.25);
    }

    /* =========================================================================
       TAB CONTENT SHELL
       ========================================================================= */
    .tab-content {
      display: none;
      animation: fadeInUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .tab-content.active {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* =========================================================================
       DASHBOARD CARD PATTERNS
       ========================================================================= */
    .card-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .card-row.two-cols {
      grid-template-columns: repeat(2, 1fr);
    }
    .card-row.three-cols {
      grid-template-columns: repeat(3, 1fr);
    }
    .card-row.one-two-cols {
      grid-template-columns: 1fr 2fr;
    }
    .card-row.two-one-cols {
      grid-template-columns: 2fr 1fr;
    }

    @media (max-width: 1024px) {
      .card-row.two-cols, .card-row.three-cols, .card-row.one-two-cols, .card-row.two-one-cols {
        grid-template-columns: 1fr !important;
      }
    }

    .dashboard-card {
      background: linear-gradient(135deg, #13131a 0%, #0d0d12 100%);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.03);
      display: flex;
      flex-direction: column;
      gap: 18px;
      position: relative;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .dashboard-card:hover {
      border-color: rgba(6, 182, 212, 0.12);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.65), 0 0 15px rgba(6, 182, 212, 0.03), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }
    .dashboard-card.cyan-glow {
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 0 20px rgba(6, 182, 212, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.04);
      border-color: rgba(6, 182, 212, 0.20);
    }
    .dashboard-card.green-glow {
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 0 20px rgba(20, 153, 116, 0.10), inset 0 1px 0 rgba(255, 255, 255, 0.04);
      border-color: rgba(20, 153, 116, 0.20);
    }
    
    .card-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--border-light);
      padding-bottom: 12px;
      gap: 12px;
    }
    .card-title-group h3 {
      font-family: var(--brand);
      font-size: 15px;
      font-weight: 700;
      color: var(--ink-primary);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-title-group h3 svg {
      color: var(--ink-dim);
      width: 17px;
      height: 17px;
    }
    .card-title-group p {
      font-size: 12px;
      color: var(--ink-dim);
      margin-top: 1px;
    }

    /* Flow Summary Wireframe Cards */
    .flow-subcard {
      border: 1px solid var(--border-light);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.01) 100%);
      border-radius: 4px;
      padding: 6px 10px;
      font-size: 9px;
      font-family: var(--sans);
      cursor: pointer;
      transition: all 0.2s ease;
      display: flex;
      flex-direction: column;
      gap: 2px;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    .flow-subcard:hover {
      transform: translateY(-1px);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.02) 100%);
      box-shadow: var(--shadow-md);
    }
    .flow-subcard.purchase {
      border-left: 3px solid var(--ink-dim);
    }
    .flow-subcard.purchase:hover {
      border-color: var(--border-hover);
      border-left-color: var(--ink-secondary);
    }
    .flow-subcard.tag {
      border-left: 3px solid var(--amber);
      border-color: rgba(207, 136, 19, 0.25);
    }
    .flow-subcard.tag:hover {
      border-color: rgba(207, 136, 19, 0.45);
      box-shadow: 0 0 10px rgba(207, 136, 19, 0.08);
    }
    .flow-subcard.sale-a {
      border-left: 3px solid var(--amber);
      border-color: rgba(207, 136, 19, 0.2);
    }
    .flow-subcard.sale-a:hover {
      border-color: rgba(207, 136, 19, 0.4);
      box-shadow: 0 0 10px rgba(207, 136, 19, 0.08);
    }
    .flow-subcard.sale-b {
      border-left: 3px solid var(--blue);
      border-color: rgba(68, 119, 210, 0.2);
    }
    .flow-subcard.sale-b:hover {
      border-color: rgba(68, 119, 210, 0.4);
      box-shadow: 0 0 10px rgba(68, 119, 210, 0.08);
    }
    .flow-subcard.schedule {
      border-left: 3px solid var(--cyan);
      border-color: rgba(6, 182, 212, 0.25);
    }
    .flow-subcard.schedule:hover {
      border-color: rgba(6, 182, 212, 0.45);
      box-shadow: 0 0 10px rgba(6, 182, 212, 0.08);
    }

    .wireframe-card {
      width: 100%;
      border: 1px solid var(--border-light);
      background: linear-gradient(135deg, rgba(255,255,255,0.015) 0%, rgba(255,255,255,0.005) 100%);
      border-radius: var(--radius-sm);
      padding: 10px;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: var(--transition);
    }
    .wireframe-card.physical-etag {
      border: 1.5px solid rgba(207, 136, 19, 0.25);
      background: linear-gradient(135deg, rgba(207, 136, 19, 0.04) 0%, rgba(207, 136, 19, 0.01) 100%);
      box-shadow: var(--shadow-amber-glow);
    }
    .wireframe-card.physical-etag:hover {
      border-color: rgba(207, 136, 19, 0.45);
      box-shadow: 0 0 15px rgba(207, 136, 19, 0.15);
    }
    .wireframe-card.schedule {
      border: 1.5px solid var(--border-focus);
      background: linear-gradient(135deg, rgba(6, 182, 212, 0.05) 0%, rgba(6, 182, 212, 0.01) 100%);
      box-shadow: var(--shadow-glow);
    }
    .wireframe-card.schedule:hover {
      border-color: var(--cyan);
      box-shadow: 0 0 15px rgba(6, 182, 212, 0.15);
    }
    .wireframe-card.purchase:hover, .wireframe-card.sales:hover {
      border-color: var(--border-hover);
      box-shadow: 0 4px 12px rgba(255, 255, 255, 0.01);
    }
    .wireframe-row-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 4px 6px;
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.01);
      border: 1px solid rgba(255, 255, 255, 0.02);
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .wireframe-row-item:hover {
      background: rgba(255, 255, 255, 0.04);
      border-color: rgba(255, 255, 255, 0.08);
    }

    /* =========================================================================
       GRAPHICAL CHART COMPONENT STYLES
       ========================================================================= */
    .chart-container {
      position: relative;
      width: 100%;
      height: 220px;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    /* Bar Performance Chart */
    .bar-chart-vertical {
      display: flex;
      justify-content: space-around;
      align-items: flex-end;
      width: 100%;
      height: 100%;
      padding-top: 20px;
      border-bottom: 2px solid var(--border-light);
    }
    .bar-column {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      width: 8%;
      cursor: pointer;
    }
    .bar-pill-container {
      width: 18px;
      height: 130px;
      background: var(--surface-input);
      border-radius: 99px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      position: relative;
      overflow: hidden;
      border: 1px solid var(--border-light);
    }
    .bar-fill {
      width: 100%;
      border-radius: 99px;
      transition: height 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    /* Dual product stack fill */
    .bar-fill.prod-a {
      background: linear-gradient(180deg, var(--red) 0%, var(--red-deep) 100%);
    }
    .bar-fill.prod-b {
      background: linear-gradient(180deg, var(--blue) 0%, var(--blue-deep) 100%);
    }
    .bar-label-top {
      font-size: 10px;
      font-family: var(--mono);
      font-weight: 600;
      color: var(--ink-primary);
      position: absolute;
      top: -20px;
      width: 100%;
      text-align: center;
    }
    .bar-axis-label {
      font-size: 9px;
      font-weight: 600;
      color: var(--ink-dim);
      text-align: center;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      width: 100%;
    }

    /* Horizontal Rules Stats */
    .horiz-rules-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .horiz-rule-item {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .horiz-rule-item.clickable {
      cursor: pointer;
      padding: 8px 12px;
      border-radius: var(--radius-sm);
      transition: var(--transition);
      border: 1px solid transparent;
    }
    .horiz-rule-item.clickable:hover {
      background: rgba(255, 255, 255, 0.015);
      border-color: var(--border-light);
    }
    .horiz-rule-item.clickable.active {
      background: linear-gradient(135deg, rgba(6, 182, 212, 0.16) 0%, rgba(6, 182, 212, 0.05) 100%) !important;
      border-color: rgba(6, 182, 212, 0.35) !important;
      border-left: 6px solid var(--cyan) !important;
      box-shadow: var(--shadow-md), 0 0 20px rgba(6, 182, 212, 0.12) !important;
      transform: scale(1.02);
    }
    .horiz-rule-item.clickable.active .horiz-rule-title {
      color: #fff !important;
      font-weight: 700;
    }
    .horiz-rule-item.clickable.active .horiz-rule-percent {
      color: var(--cyan) !important;
      font-weight: 700;
    }
    .horiz-rule-item.clickable.active .horiz-bar-fill.slate {
      background: linear-gradient(90deg, var(--cyan) 0%, var(--cyan-deep) 100%) !important;
      box-shadow: 0 0 8px var(--cyan-glow);
    }
    .horiz-rule-header {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      font-weight: 500;
    }
    .horiz-rule-title {
      color: var(--ink-secondary);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .horiz-rule-percent {
      font-family: var(--mono);
      font-weight: 600;
      color: var(--ink-primary);
    }
    .horiz-bar-bg {
      width: 100%;
      height: 8px;
      background: var(--surface-input);
      border-radius: 99px;
      overflow: hidden;
      border: 1px solid var(--border-light);
      display: flex;
    }
    .horiz-bar-fill {
      height: 100%;
      transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .horiz-bar-fill.red { background: var(--red); }
    .horiz-bar-fill.amber { background: var(--amber); }
    .horiz-bar-fill.blue { background: var(--blue); }
    .horiz-bar-fill.green { background: var(--green); }
    .horiz-bar-fill.slate { background: var(--ink-muted); }

    /* =========================================================================
       DATA TABLES STYLE
       ========================================================================= */
    .table-container {
      overflow-x: auto;
      width: 100%;
    }
    .dashboard-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 13px;
    }
    .dashboard-table th {
      background: var(--surface-input);
      color: var(--ink-dim);
      font-family: var(--brand);
      font-size: 11px;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.05em;
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.09);
    }
    .dashboard-table td {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      color: var(--ink-secondary);
      transition: var(--transition);
      vertical-align: middle;
    }
    .dashboard-table tr:hover td {
      background: rgba(255, 255, 255, 0.015);
      color: var(--ink-primary);
    }
    .dashboard-table tr.clickable {
      cursor: pointer;
    }
    .dashboard-table tr.active td {
      background: rgba(6, 182, 212, 0.12) !important;
      color: #fff !important;
      font-weight: 600;
    }
    .dashboard-table tr.active td:first-child {
      border-left: 4px solid var(--cyan) !important;
    }
    .dashboard-table tr.active td strong {
      color: var(--cyan) !important;
    }
    .dashboard-table tr.even-block td {
      background: rgba(255, 255, 255, 0.012) !important;
    }
    .dashboard-table tr.odd-block td {
      background: rgba(0, 0, 0, 0.1) !important;
    }
    .dashboard-table tr.block-start td {
      border-top: 1.5px solid rgba(255, 255, 255, 0.08) !important;
    }
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 99px;
      letter-spacing: 0.04em;
    }
    .status-badge.red {
      background: var(--red-glow);
      color: var(--red);
      border: 1px solid rgba(214, 69, 91, 0.15);
    }
    .status-badge.blue {
      background: var(--blue-glow);
      color: var(--blue);
      border: 1px solid rgba(68, 119, 210, 0.15);
    }
    .status-badge.green {
      background: var(--green-glow);
      color: var(--green);
      border: 1px solid rgba(20, 153, 116, 0.15);
    }
    .status-badge.amber {
      background: var(--amber-glow);
      color: var(--amber);
      border: 1px solid rgba(207, 136, 19, 0.15);
    }
    .status-badge.purple {
      background: var(--purple-glow);
      color: var(--purple);
      border: 1px solid rgba(168, 85, 247, 0.15);
    }
    .status-badge.orange {
      background: var(--orange-glow);
      color: var(--orange);
      border: 1px solid rgba(249, 115, 22, 0.15);
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      display: inline-block;
    }
    .status-dot.red { background: var(--red); }
    .status-dot.blue { background: var(--blue); }
    .status-dot.green { background: var(--green); }
    .status-dot.amber { background: var(--amber); }
    .status-dot.orange { background: var(--orange); }
    .status-dot.purple { background: var(--purple); }

    /* =========================================================================
       WORKFLOW STAGE MAP
       ========================================================================= */
    .workflow-map {
      display: flex;
      flex-direction: column;
      gap: 16px;
      padding: 10px 0;
    }
    .workflow-step {
      display: flex;
      align-items: center;
      background: var(--surface-input);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-sm);
      padding: 12px 16px;
      cursor: pointer;
      transition: var(--transition);
      gap: 12px;
      position: relative;
    }
    .workflow-step:hover {
      border-color: var(--border-hover);
      background: rgba(255, 255, 255, 0.01);
      transform: translateX(4px);
    }
    .workflow-step::after {
      content: '';
      position: absolute;
      left: 24px;
      bottom: -16px;
      width: 2px;
      height: 16px;
      background: var(--border-light);
      z-index: 0;
    }
    .workflow-step:last-child::after {
      display: none;
    }
    .workflow-num {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--border-light);
      color: var(--ink-dim);
      font-size: 11px;
      font-weight: 700;
      display: grid;
      place-items: center;
      font-family: var(--brand);
      z-index: 1;
    }
    .workflow-step:hover .workflow-num {
      background: var(--red);
      color: #fff;
    }
    .workflow-details h4 {
      font-size: 13px;
      font-weight: 600;
      color: var(--ink-primary);
    }
    .workflow-details p {
      font-size: 11px;
      color: var(--ink-dim);
    }

    /* =========================================================================
       DYNAMIC LINKAGE TREE/NETWORK VIEWER
       ========================================================================= */
    .linkage-grid {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 20px;
      min-height: 450px;
    }
    @media (max-width: 768px) {
      .linkage-grid {
        grid-template-columns: 1fr;
      }
    }
    .schedule-list-pane {
      border-right: 1px solid var(--border-light);
      padding-right: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      max-height: 500px;
      overflow-y: auto;
    }
    .schedule-pill-btn {
      background: var(--surface-input);
      border: 1px solid var(--border-light);
      padding: 10px 14px;
      border-radius: var(--radius-sm);
      text-align: left;
      cursor: pointer;
      transition: var(--transition);
      display: flex;
      flex-direction: column;
      gap: 4px;
      width: 100%;
    }
    .schedule-pill-btn:hover {
      border-color: rgba(6, 182, 212, 0.20);
      background: rgba(255, 255, 255, 0.01);
    }
    .schedule-pill-btn.active {
      background: rgba(6, 182, 212, 0.05);
      border-color: var(--cyan);
      box-shadow: 0 0 10px var(--cyan-glow);
    }
    .schedule-pill-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
    }
    .schedule-pill-title {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 700;
      color: var(--ink-primary);
    }
    .schedule-pill-desc {
      font-size: 11px;
      color: var(--ink-dim);
    }

    .linkage-diagram-pane {
      background: var(--surface-input);
      border: 1px solid var(--border-light);
      border-radius: var(--radius);
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      justify-content: center;
    }
    .diagram-nodes-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: relative;
      flex-wrap: wrap;
      gap: 30px;
    }
    /* SVG Connectors Background overlay */
    .diagram-svg-overlay {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }
    .diagram-column {
      display: flex;
      flex-direction: column;
      gap: 16px;
      z-index: 1;
      flex: 1;
      align-items: center;
      min-width: 180px;
    }
    .diagram-column-title {
      font-size: 10px;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--ink-dim);
      letter-spacing: 0.05em;
      margin-bottom: 4px;
    }
    .diagram-node {
      background: var(--surface-card);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-sm);
      padding: 12px;
      width: 100%;
      max-width: 220px;
      box-shadow: var(--shadow-sm);
      transition: var(--transition);
      cursor: pointer;
      position: relative;
    }
    .diagram-node:hover {
      border-color: var(--border-hover);
      transform: scale(1.02);
      box-shadow: var(--shadow-md);
    }
    .diagram-node.active-highlight {
      border-color: var(--cyan);
      box-shadow: 0 0 12px var(--cyan-glow);
    }
    .diagram-node-title {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 700;
      color: var(--ink-primary);
      display: flex;
      justify-content: space-between;
    }
    .diagram-node-body {
      font-size: 11px;
      color: var(--ink-dim);
      margin-top: 4px;
      display: flex;
      justify-content: space-between;
    }
    
    /* Flow connectors */
    .node-connector-line {
      flex: 0.1;
      height: 2px;
      background: var(--border-light);
      min-width: 20px;
      z-index: 0;
      position: relative;
    }
    .node-connector-line.active {
      background: var(--cyan);
      box-shadow: 0 0 6px var(--cyan-glow);
    }

    /* =========================================================================
       SIDE DRAWER FOR DETAILS & ADJUSTMENTS
       ========================================================================= */
    .drawer-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
      z-index: 100;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.25s ease;
    }
    .drawer-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }
    .drawer-pane {
      position: fixed;
      top: 0; right: -420px; width: 420px; height: 100%;
      background: #0d0d12;
      border-left: 1px solid rgba(255, 255, 255, 0.05);
      box-shadow: -8px 0 32px rgba(0, 0, 0, 0.8);
      z-index: 101;
      transition: right 0.28s cubic-bezier(0.16, 1, 0.3, 1);
      display: flex;
      flex-direction: column;
    }
    .drawer-pane.active {
      right: 0;
    }
    .drawer-header {
      padding: 20px 24px;
      border-bottom: 1px solid var(--border-light);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .drawer-header h3 {
      font-family: var(--brand);
      font-size: 16px;
      font-weight: 700;
      color: var(--ink-primary);
    }
    .drawer-close-btn {
      background: transparent;
      border: none;
      color: var(--ink-dim);
      cursor: pointer;
      outline: none;
      transition: var(--transition);
    }
    .drawer-close-btn:hover {
      color: var(--red);
    }
    .drawer-content {
      padding: 24px;
      overflow-y: auto;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    
    .detail-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .detail-label {
      font-size: 10px;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--ink-dim);
      letter-spacing: 0.05em;
    }
    .detail-value {
      font-family: var(--sans);
      font-size: 13px;
      color: var(--ink-primary);
    }
    .detail-value.mono {
      font-family: var(--mono);
    }
    
    .timeline-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
      border-left: 2px solid var(--border-light);
      padding-left: 14px;
      margin-left: 6px;
      margin-top: 10px;
    }
    .timeline-item {
      position: relative;
    }
    .timeline-dot {
      position: absolute;
      left: -20px;
      top: 5px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--ink-muted);
      border: 2px solid #0d0d12;
    }
    .timeline-dot.ok { background: var(--green); }
    .timeline-dot.active { background: var(--red); }
    .timeline-time {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--ink-dim);
    }
    .timeline-text {
      font-size: 12px;
      color: var(--ink-secondary);
      margin-top: 2px;
    }

    /* Config panel style */
    .config-box {
      background: var(--surface-input);
      border: 1px solid var(--border-light);
      border-radius: var(--radius-sm);
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .config-title {
      font-family: var(--brand);
      font-size: 12px;
      font-weight: 700;
      color: var(--ink-primary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .config-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .config-field label {
      font-size: 10px;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--ink-dim);
    }
    .config-input {
      background: var(--surface-card);
      border: 1px solid var(--border-light);
      color: var(--ink-primary);
      padding: 6px 10px;
      border-radius: var(--radius-sm);
      font-family: var(--mono);
      font-size: 12px;
      outline: none;
      transition: var(--transition);
    }
    .config-input:focus {
      border-color: var(--border-focus);
    }

    /* XML code viewer block */
    .xml-code-block {
      background: #050507;
      border: 1px solid var(--border-light);
      border-radius: var(--radius-sm);
      padding: 12px;
      font-family: var(--mono);
      font-size: 11px;
      color: #6ee7b7;
      white-space: pre-wrap;
      overflow-x: auto;
      max-height: 200px;
    }

    /* Ingestion & Reconciliation Matrix Table Styles */
    .matrix-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 12px;
    }
    .matrix-table th {
      background: var(--surface-input);
      color: var(--ink-dim);
      font-family: var(--brand);
      font-size: 10px;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.05em;
      padding: 10px 14px;
      border-bottom: 2px solid var(--border-light);
      border-right: 1px solid var(--border-light);
    }
    .matrix-table th:last-child {
      border-right: none;
    }
    .matrix-table td {
      padding: 10px 14px;
      border-bottom: 1px solid var(--border-light);
      border-right: 1px solid rgba(255, 255, 255, 0.03);
      vertical-align: middle;
      color: var(--ink-secondary);
      transition: var(--transition);
    }
    .matrix-table td:last-child {
      border-right: none;
    }
    /* Bold borders to separate location blocks */
    .matrix-table tr.loc-boundary-row td {
      border-top: 2px solid rgba(6, 182, 212, 0.15) !important;
    }
    /* Spanned cell background and text styling */
    .matrix-table td.spanned-loc {
      background: rgba(255, 255, 255, 0.01);
      font-family: var(--brand);
      font-weight: 600;
      color: var(--ink-primary);
    }
    .matrix-table td.spanned-profile {
      background: rgba(255, 255, 255, 0.005);
    }
    .matrix-table td.spanned-schedule {
      background: rgba(255, 255, 255, 0.01);
    }
    .matrix-table tr:hover td {
      background: rgba(255, 255, 255, 0.015) !important;
    }
    /* Interactive Pills */
    .matrix-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 6px;
      font-family: var(--mono);
      font-size: 11px;
      font-weight: 500;
      cursor: pointer;
      border: 1px solid var(--border-light);
      background: var(--surface-card);
      transition: var(--transition);
      color: var(--ink-secondary);
      text-decoration: none;
    }
    .matrix-pill:hover {
      border-color: var(--border-focus);
      transform: translateY(-1px);
      box-shadow: var(--shadow-sm);
      color: var(--ink-primary);
    }
    .matrix-pill.pill-tag {
      border-color: rgba(207, 136, 19, 0.15);
    }
    .matrix-pill.pill-tag:hover {
      border-color: var(--amber);
      background: rgba(207, 136, 19, 0.04);
    }
    .matrix-pill.pill-purch {
      border-color: rgba(255, 255, 255, 0.06);
    }
    .matrix-pill.pill-purch:hover {
      border-color: var(--ink-primary);
      background: rgba(255, 255, 255, 0.02);
    }
    .matrix-pill.pill-sale-a {
      border-color: rgba(207, 136, 19, 0.18);
      background: rgba(207, 136, 19, 0.02);
      color: var(--amber);
      font-weight: 600;
    }
    .matrix-pill.pill-sale-a:hover {
      border-color: var(--amber);
      background: rgba(207, 136, 19, 0.06);
    }
    .matrix-pill.pill-sale-b {
      border-color: rgba(68, 119, 210, 0.18);
      background: rgba(68, 119, 210, 0.02);
      color: var(--blue);
      font-weight: 600;
    }
    .matrix-pill.pill-sale-b:hover {
      border-color: var(--blue);
      background: rgba(68, 119, 210, 0.06);
    }
    .matrix-pill.pill-schedule {
      border-color: rgba(20, 153, 116, 0.15);
      background: rgba(20, 153, 116, 0.02);
      color: var(--green);
      font-weight: 600;
    }
    .matrix-pill.pill-schedule:hover {
      border-color: var(--green);
      background: rgba(20, 153, 116, 0.06);
    }
    .matrix-table tr.active-matrix-row td {
      background: rgba(6, 182, 212, 0.05) !important;
    }
    .matrix-table tr.active-matrix-row td.spanned-loc {
      border-left: 4px solid var(--cyan) !important;
      background: rgba(6, 182, 212, 0.08) !important;
    }
    .matrix-table td.spanned-loc.clickable-row {
      cursor: pointer;
      transition: var(--transition);
    }
    .matrix-table td.spanned-loc.clickable-row:hover {
      background: rgba(6, 182, 212, 0.08) !important;
      color: var(--cyan) !important;
    }
    @keyframes pulse-border-red {
      0% { border-color: rgba(214, 69, 91, 0.3); box-shadow: 0 0 4px rgba(214, 69, 91, 0.1); }
      50% { border-color: rgba(214, 69, 91, 1.0); box-shadow: 0 0 12px rgba(214, 69, 91, 0.3); }
      100% { border-color: rgba(214, 69, 91, 0.3); box-shadow: 0 0 4px rgba(214, 69, 91, 0.1); }
    }
    .mismatch-pulse-red {
      animation: pulse-border-red 2s infinite ease-in-out;
    }

    /* =========================================================================
       TOAST NOTIFICATIONS CONTAINER & POPUPS
       ========================================================================= */
    .toast-container {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 2000;
      display: flex;
      flex-direction: column-reverse;
      gap: 10px;
      pointer-events: none;
    }
    .toast {
      background: var(--surface-card);
      border-left: 4px solid var(--green);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      border-right: 1px solid var(--border);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      padding: 14px 18px;
      min-width: 320px;
      max-width: 420px;
      box-shadow: var(--shadow-lg);
      display: flex;
      align-items: flex-start;
      gap: 12px;
      pointer-events: all;
      transform: translateY(20px);
      opacity: 0;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .toast.active {
      transform: translateY(0);
      opacity: 1;
    }
    .toast-icon {
      color: var(--green);
      flex-shrink: 0;
    }
    .toast-icon svg {
      width: 18px;
      height: 18px;
    }
    .toast-body {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .toast-title {
      font-size: 13.5px;
      font-weight: 700;
      color: var(--ink-primary);
    }
    .toast-message {
      font-size: 12px;
      color: var(--ink-dim);
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .animate-spin {
      animation: spin 1s linear infinite;
    }
    
    /* Calendar Popover styles */
    .calendar-popover {
      display: none;
      position: absolute;
      top: calc(100% + 6px);
      right: 0;
      z-index: 1000;
      background: #111116;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
      width: 250px;
      padding: 12px;
      font-family: var(--brand);
      user-select: none;
    }
    .calendar-popover button {
      background: none;
      border: none;
      color: var(--ink-primary);
      cursor: pointer;
    }
    .calendar-day-cell {
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 4px;
      cursor: pointer;
      transition: var(--transition);
      color: var(--ink-primary);
    }
    .calendar-day-cell:hover:not(.empty-cell):not(.selected-day) {
      background: var(--surface-card-hover);
      color: var(--ink-primary);
    }
    .calendar-day-cell.selected-day {
      background: var(--amber);
      color: #000 !important;
      font-weight: 700;
    }
    .calendar-day-cell.empty-cell {
      cursor: default;
    }
    .calendar-day-cell.today-cell {
      border: 1px solid rgba(207, 136, 19, 0.4);
    }
    
    /* Muted Row Actions */
    .btn-row-action {
      background: transparent !important;
      border: none !important;
      color: var(--ink-dim) !important;
      padding: 4px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition);
      border-radius: 4px;
    }
    .btn-row-action.accept:hover {
      color: var(--green) !important;
      background: rgba(20, 153, 116, 0.1) !important;
    }
    .btn-row-action.reject:hover {
      color: var(--red) !important;
      background: rgba(214, 69, 91, 0.1) !important;
    }
    
    /* SVG Chart Animations */
    @keyframes drawLine {
      from { stroke-dashoffset: 1500; }
      to { stroke-dashoffset: 0; }
    }
    @keyframes growBar {
      from { transform: scaleY(0); }
      to { transform: scaleY(1); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .animated-net-line {
      stroke-dasharray: 1500;
      stroke-dashoffset: 1500;
      animation: drawLine 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animated-bar {
      transform-origin: 0px 100px; /* Base yZero at 100px */
      animation: growBar 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animated-fade {
      opacity: 0;
      animation: fadeIn 0.6s ease-out forwards;
    }
    
    /* Header Date Trigger & Settings button hover styles */
    #date-picker-trigger {
      transition: var(--transition);
    }
    #date-picker-trigger:hover {
      color: var(--cyan) !important;
    }
    #date-picker-trigger:hover i, #date-picker-trigger:hover svg {
      color: var(--cyan) !important;
    }
    .btn-settings-icon {
      background: transparent !important;
      border: none !important;
      color: var(--ink-dim) !important;
      padding: 4px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition);
      border-radius: 4px;
      outline: none;
    }
    .btn-settings-icon:hover {
      color: var(--cyan) !important;
    }
    .btn-settings-icon:hover svg, .btn-settings-icon:hover i {
      transform: rotate(30deg);
      transition: var(--transition);
    }
  </style>
</head>
