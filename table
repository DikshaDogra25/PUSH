      kpiDetailsPopup.style.position = "fixed";
    }
    const scheduleTagTooltip = document.getElementById("schedule-tag-tooltip");
    if (scheduleTagTooltip) {
      document.body.appendChild(scheduleTagTooltip);
      scheduleTagTooltip.style.position = "fixed";
    }

    // Run the engine
    runAllocationEngine();
    // Auto-select the boundary location where Product B usage begins
    if (STATE.boundaryLocation && STATE.boundaryLocation !== "None") {
      STATE.selectedLocName = STATE.boundaryLocation;
    }
    // Render the initial UI
    renderAll();

    // Initialize calendar trigger click handler
    const trigger = document.getElementById("date-picker-trigger");
    if (trigger) {
      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleCalendarPopover();
      });
    }

    // Global listener to close dropdowns and popovers when clicking outside
    document.addEventListener("click", (e) => {
      // Close location state actions dropdown menu
      const menu = document.getElementById("loc-action-dropdown-menu");
      if (menu && !e.target.closest("#loc-action-btn-group")) {
        menu.style.display = "none";
      }

      // Close calendar popover
      const popover = document.getElementById("calendar-popover");
      const trig = document.getElementById("date-picker-trigger");
      if (popover && trig && !e.target.closest("#calendar-popover") && !trig.contains(e.target)) {
        popover.style.display = "none";
      }
    });
