  function renderSchedulesTab() {
    const getSchStatus = (sch) => {
      const ls = STATE.locationStates[sch.location] || 'Draft';
      return STATE.committed ? 'Committed' : (ls === 'Accepted' ? 'Accepted' : ls === 'Rejected' ? 'Rejected' : 'Pending');
    };

    const sPendCount = STATE.schedules.filter(s => getSchStatus(s) === 'Pending').length;
    const sAccCount = STATE.schedules.filter(s => getSchStatus(s) === 'Accepted').length;
    const sRejCount = STATE.schedules.filter(s => getSchStatus(s) === 'Rejected').length;
    const sCommCount = STATE.schedules.filter(s => getSchStatus(s) === 'Committed').length;
    renderTabFilterPills('schedules-filter-pills', 'schedules', [
      { key: 'All', label: 'All', count: STATE.schedules.length },
      { key: 'Pending', label: 'Planned', count: sPendCount },
      { key: 'Accepted', label: 'Accepted', count: sAccCount },
      { key: 'Rejected', label: 'Rejected', count: sRejCount },
      { key: 'Committed', label: 'Committed', count: sCommCount },
    ]);

    const schedFilter = STATE.tabFilters.schedules;
    const filteredSchedules = schedFilter === 'All'
      ? STATE.schedules
      : STATE.schedules.filter(s => getSchStatus(s) === schedFilter);

    // Left panel: Selection list (may be absent if visual panel removed)
    const listContainer = document.getElementById("schedules-list-container");
    if (listContainer) {
      listContainer.innerHTML = "";
      filteredSchedules.forEach(sch => {
        const activeClass = (sch.id === STATE.selectedScheduleId) ? "active" : "";
        const schDispStatus = getSchStatus(sch);
        const schDispColor = (schDispStatus === 'Committed' || schDispStatus === 'Accepted') ? 'green' : schDispStatus === 'Rejected' ? 'red' : 'amber';
        const itemHTML = `
          <button class="schedule-pill-btn ${activeClass}" onclick="selectSchedule('${sch.id}')">
            <div class="schedule-pill-header">
              <span class="schedule-pill-title">SCH #${sch.schedule_num}</span>
              <span class="status-badge ${schDispColor}" style="font-size:8px; padding:1px 6px;">${schDispStatus}</span>
            </div>
            <div class="schedule-pill-desc">Tag: <strong>${sch.tag_code}</strong> - Total: <strong>${sch.total_mw} MWh</strong></div>
          </button>
        `;
        listContainer.insertAdjacentHTML("beforeend", itemHTML);
      });
      updateScheduleDiagram();
    }

    // Right panel: Tabular grid view showing schedule list with properties & sparklines
    const tableBody = document.querySelector("#schedules-tabular-grid tbody");
    if (!tableBody) return;
    tableBody.innerHTML = "";
    filteredSchedules.forEach((sch, schIdx) => {
      const tagPurchases = STATE.purchaseDeals.filter(p => sch.purchase_deal_ids.includes(p.id));
      const tagSales = sch.sale_deals.map(sd => {
        const deal = STATE.saleDeals.find(s => s.id === sd.deal_id);
        return {
          deal_num: deal ? deal.deal_num : sd.deal_id,
          counterparty: deal ? deal.counterparty : "Amazon Energy Services",
          product: deal ? deal.product : "Sale Product",
          mw: sd.mw,
          id: sd.deal_id
        };
      });

      const rowsList = [];
      tagPurchases.forEach(p => {
        rowsList.push({
          type: "Purchase",
          deal_num: p.deal_num,
          counterparty: p.counterparty,
          product: p.product,
          mw: `-${p.mw.toFixed(1)}`,
          id: p.id,
          entityType: "PurchaseDeal"
        });
      });
      tagSales.forEach(s => {
        rowsList.push({
          type: "Sale",
          deal_num: s.deal_num,
          counterparty: s.counterparty,
          product: s.product,
          mw: `+${s.mw.toFixed(1)}`,
          id: s.id,
          entityType: "SaleDeal"
        });
      });

      const N = Math.max(rowsList.length, 1);

      const locState = STATE.locationStates[sch.location] || 'Draft';
      const unifiedStatus = STATE.committed ? 'Committed' : (locState === 'Accepted' ? 'Accepted' : locState === 'Rejected' ? 'Rejected' : 'Pending');
      const unifiedColor = (unifiedStatus === 'Committed' || unifiedStatus === 'Accepted') ? 'green' : unifiedStatus === 'Rejected' ? 'red' : 'amber';

      const statusActionsCell = `
        <td rowspan="${N}" style="text-align: center; vertical-align: middle; border-left: 1px solid var(--border-light); padding: 8px;">
          <div style="display: flex; flex-direction: column; align-items: center; gap: 6px;">
            <span class="status-badge ${unifiedColor}" style="display:inline-block;">${unifiedStatus}</span>
            <div style="display: inline-flex; gap: 14px; align-items: center; margin-top: 4px;">
              <button type="button" class="btn-row-action accept" onclick="acceptScheduleRow('${sch.id}')" title="Accept Schedule">
                <i data-lucide="check" style="width: 14px; height: 14px;"></i>
              </button>
              <button type="button" class="btn-row-action reject" onclick="rejectScheduleRow('${sch.id}')" title="Reject Schedule">
                <i data-lucide="x" style="width: 14px; height: 14px;"></i>
              </button>
            </div>
          </div>
        </td>
      `;

      const blockClass = (schIdx % 2 === 0) ? "even-block" : "odd-block";
      for (let i = 0; i < N; i++) {
        const item = rowsList[i];
        let trClass = blockClass;
        if (i === 0) trClass += " block-start";
        let trHTML = `<tr class="${trClass}">`;
        
        if (i === 0) {
          // Render row-spanned columns
          trHTML += `
            <td rowspan="${N}" style="text-align: center; vertical-align: middle;"><input type="checkbox" class="schedule-checkbox" data-sch-id="${sch.id}" onchange="updateSelectAllState()" style="cursor: pointer;"/></td>
            <td rowspan="${N}" style="font-family:var(--mono); font-weight:600; color:var(--ink-primary); vertical-align: middle; cursor: pointer;" onmousemove="showFlowTooltip(event, 'Schedule', '${sch.id}', '${sch.location}')" onmouseout="hideFlowTooltip()">${sch.schedule_num}</td>
            <td rowspan="${N}" style="font-family:var(--mono); color:var(--amber); vertical-align: middle; cursor: pointer;" onmousemove="showScheduleTagTooltip(event, '${sch.tag_code}')" onmouseout="hideScheduleTagTooltip()">${sch.tag_code}</td>
            <td rowspan="${N}" style="vertical-align: middle; cursor: pointer;" onmousemove="showFlowTooltip(event, 'Schedule', '${sch.id}', '${sch.location}')" onmouseout="hideFlowTooltip()">${sch.source} ? ${sch.sink}</td>
          `;
        }

        // Render deal columns
        if (item) {
          const typeBadgeColor = item.type === 'Purchase' ? 'orange' : 'green';
          const volColor = item.type === 'Purchase' ? 'var(--orange)' : 'var(--green)';
          const dealNumColor = item.type === 'Purchase' ? 'var(--ink-primary)' : 'var(--green)';
          const displayNum = item.deal_num.replace(/^P-/, '');
          const hoverAttrs = `onmousemove="showFlowTooltip(event, '${item.entityType}', '${item.id}', '${sch.location}')" onmouseout="hideFlowTooltip()"`;

          trHTML += `
            <td><span class="status-badge ${typeBadgeColor}" style="display:inline-block;">${item.type}</span></td>
            <td style="font-family:var(--mono); font-weight:600; color:${dealNumColor}; cursor:pointer;" onclick="openDrawer('${item.entityType}', '${item.id}')" ${hoverAttrs}>${displayNum}</td>
            <td>${item.counterparty}</td>
            <td>${item.product}</td>
            <td style="font-family:var(--mono); font-weight:600; color:${volColor}; text-align:right;">${item.mw}</td>
          `;
        } else {
          trHTML += `
            <td>-</td>
            <td>-</td>
            <td>-</td>
            <td>-</td>
            <td>-</td>
          `;
        }

        if (i === 0) {
          trHTML += statusActionsCell;
        }

        trHTML += "</tr>";
        tableBody.insertAdjacentHTML("beforeend", trHTML);
      }
    });

    updateSelectAllState();
  }
  // Toast notifications helper
  function showToast(title, message, type = "success") {
    const container = document.getElementById("toast-container");
    if (!container) return;
    
    const toast = document.createElement("div");
    toast.className = "toast";
    
    let borderClr = "var(--green)";
    let iconSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';

    if (type === "info") {
      borderClr = "var(--cyan)";
      toast.style.borderLeftColor = "var(--cyan)";
      iconSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.086.797l-2.22 2.22a.75.75 0 11-1.06-1.06l1.22-1.22L9 12h.75M12 8.25h.008v.008H12V8.25zM21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
    } else if (type === "warning") {
      borderClr = "var(--orange)";
      toast.style.borderLeftColor = "var(--orange)";
      iconSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    } else if (type === "error" || type === "danger") {
      borderClr = "var(--red)";
      toast.style.borderLeftColor = "var(--red)";
      iconSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    }

    toast.innerHTML = `
      <div class="toast-icon" style="color: ${borderClr}">${iconSvg}</div>
      <div class="toast-body">
        <div class="toast-title">${title}</div>
        <div class="toast-message">${message}</div>
      </div>
    `;

    container.appendChild(toast);
    
    // Force repaint
    toast.offsetHeight;
    toast.classList.add("active");

    // Auto dismiss
    setTimeout(() => {
      toast.classList.remove("active");
      setTimeout(() => {
        toast.remove();
      }, 300);
    }, 4000);
  }

  // Helper to determine the dynamic location state based on its tags' statuses
  function getLocationState(locName) {
    const locTags = STATE.tags.filter(t => t.location === locName);
    if (locTags.length > 0 && locTags.every(t => t.status === "Committed")) {
      return "Committed";
    }
    return STATE.locationStates[locName] || "Draft";
  }

  // Location Accept/Reject workflow functions
  function acceptCurrentLocation() {
    const locName = STATE.selectedLocName;
    if (!locName) return;
    if (getLocationState(locName) === 'Committed') {
      showToast("Already Committed", "This location schedule is committed and locked.", "info");
      return;
    }
    
    STATE.locationStates[locName] = 'Accepted';
    STATE.tags.forEach(t => {
      if (t.location === locName && t.status !== 'Committed') {
        t.status = 'Accepted';
      }
    });
    showToast("Location Accepted", `Schedule for ${locName} has been accepted.`, "success");
    selectNextLocation();
    renderAll();
  }

  function rejectCurrentLocation() {
    const locName = STATE.selectedLocName;
    if (!locName) return;
    if (getLocationState(locName) === 'Committed') {
      showToast("Already Committed", "This location schedule is committed and locked.", "info");
      return;
    }
    
    STATE.locationStates[locName] = 'Rejected';
    STATE.tags.forEach(t => {
      if (t.location === locName && t.status !== 'Committed') {
        t.status = 'Rejected';
      }
    });
    showToast("Location Rejected", `Schedule for ${locName} has been marked as rejected.`, "info");
    selectNextLocation();
    renderAll();
  }

  function acceptScheduleRow(schId) {
    const sch = STATE.schedules.find(s => s.id === schId);
    if (!sch) return;
    if (getLocationState(sch.location) === 'Committed') {
      showToast("Already Committed", "This location schedule is committed and locked.", "info");
      return;
    }
    
    STATE.locationStates[sch.location] = 'Accepted';
    STATE.tags.forEach(t => {
      if (t.tag_code === sch.tag_code && t.status !== 'Committed') {
        t.status = 'Accepted';
      }
    });
    showToast("Schedule Accepted", `Schedule ${schId} has been accepted.`, "success");
    renderAll();
  }

  function rejectScheduleRow(schId) {
    const sch = STATE.schedules.find(s => s.id === schId);
    if (!sch) return;
    if (getLocationState(sch.location) === 'Committed') {
      showToast("Already Committed", "This location schedule is committed and locked.", "info");
      return;
    }
    
    STATE.locationStates[sch.location] = 'Rejected';
    STATE.tags.forEach(t => {
      if (t.tag_code === sch.tag_code && t.status !== 'Committed') {
        t.status = 'Rejected';
      }
    });
    showToast("Schedule Rejected", `Schedule ${schId} has been marked as rejected.`, "info");
    renderAll();
  }

  function selectNextLocation() {
    const visibleLocs = getFilteredOverviewLocations();
    if (visibleLocs.length <= 1) {
      if (visibleLocs.length === 1) {
        STATE.selectedLocName = visibleLocs[0].name;
