  window.addEventListener("DOMContentLoaded", () => {
    // Append tooltips to body and use fixed position for reliable screen-relative alignment
    const flowTooltip = document.getElementById("flow-tooltip");
    if (flowTooltip) {
      document.body.appendChild(flowTooltip);
      flowTooltip.style.position = "fixed";
    }
    const clearanceTooltip = document.getElementById("clearance-tooltip");
