  // Simulate physical Tag drift in real time
  function simulateTagDrift() {
    if (STATE.committed) {
      const conf = confirm("The schedule plan is currently COMMITTED. Simulating drift will reset commitment to draft state. Proceed?");
      if (!conf) return;
      STATE.committed = false;
      STATE.tags.forEach(t => t.status = "Unscheduled");
    }

    // Pick a random tag and adjust MW by +/- 5 to 15 MW
    const randIndex = Math.floor(Math.random() * STATE.tags.length);
    const tag = STATE.tags[randIndex];
    const change = (Math.random() > 0.5 ? 1 : -1) * (Math.floor(Math.random() * 3) + 1) * 5; // steps of 5
    
    const oldMw = tag.mw;
    tag.mw = Math.max(5, tag.mw + change);

    runAllocationEngine();
    if (STATE.boundaryLocation && STATE.boundaryLocation !== "None") {
      STATE.selectedLocName = STATE.boundaryLocation;
    }
    renderAll();
    
    alert(`[Tag Drift Inbound]: Tag ${tag.id} at ${tag.location} updated from ${oldMw} MW to ${tag.mw} MW. Allocation Engine has re-balanced all contracts.`);
  }

  // Commit schedule draft plan
  function commitSchedulePlan() {
    if (STATE.committed) {
      showToast("Plan Committed", "Plan is already fully committed to the E-Tagging and Settlement system.", "info");
      return;
    }

    // Check if there is at least one decided location (Accepted or Rejected) that is not yet committed
    const locsToCommit = STATE.locations.filter(loc => {
      const s = STATE.locationStates[loc.name];
      const isCommitted = getLocationState(loc.name) === 'Committed';
      return (s === 'Accepted' || s === 'Rejected') && !isCommitted;
    });

    if (locsToCommit.length === 0) {
      showToast("No Decided Schedules", "Please accept or reject at least one schedule before committing.", "warning");
      return;
    }

    // Check if there is an imbalance in any of the locations being committed
    let hasImbalance = false;
    locsToCommit.forEach(loc => {
      const locPurch = STATE.purchaseDeals.filter(p => p.location === loc.name);
      const purchSum = locPurch.reduce((sum, p) => sum + p.mw, 0);
      if (Math.abs(loc.totalMW - purchSum) > 0.1) {
        hasImbalance = true;
      }
    });

    if (hasImbalance) {
      const conf = confirm("WARNING: One or more locations being committed have a balancing imbalance. Force commit?");
      if (!conf) return;
    }

    // Disable button and show loading text
    const btn = document.getElementById("btn-commit-plan");
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = `<i data-lucide="loader" class="animate-spin" style="width: 14px; height: 14px; margin-right: 4px;"></i> Posting Plan...`;
    if (window.lucide) lucide.createIcons();

    setTimeout(() => {
      // Commit selected locations
      locsToCommit.forEach(loc => {
        // Update tags
        STATE.tags.forEach(t => {
          if (t.location === loc.name) {
            t.status = "Committed";
          }
        });
        // Update purchases
        STATE.purchaseDeals.forEach(p => {
          if (p.location === loc.name) {
            p.status = "Existing";
          }
        });
        // Update schedules
        STATE.schedules.forEach(sc => {
          if (sc.location === loc.name) {
            sc.status = "Committed";
          }
        });
      });

      // Update global committed if ALL locations are committed
      const allCommitted = STATE.locations.every(loc => getLocationState(loc.name) === 'Committed');
      if (allCommitted) {
        STATE.committed = true;
        STATE.saleDeals.forEach(s => s.status = "Committed");
      }

      btn.disabled = false;
      btn.innerHTML = originalText;

      renderAll();
      showToast("Schedules Committed", `Successfully committed ${locsToCommit.length} location schedule plan(s) to settlements server.`, "success");
    }, 1500);
  }

