from langgraph.graph import StateGraph, START, END
from langchain_core.tools import BaseTool
from .state import SalesAgentState
from .nodes import make_fetch_template, build_deals


def build_sales_graph(tools: list[BaseTool]):
    workflow = StateGraph(SalesAgentState)

    # No call_model — input comes from the first agent, not a prompt
    workflow.add_node("fetch_template", make_fetch_template(tools))
    workflow.add_node("build_deals", build_deals)

    workflow.add_edge(START, "fetch_template")
    workflow.add_edge("fetch_template", "build_deals")
    workflow.add_edge("build_deals", END)

    return workflow.compile()  # TODO: add persistent checkpointer
