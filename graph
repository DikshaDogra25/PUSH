from langgraph.graph import StateGraph, START, END
from langchain_core.tools import BaseTool
from .state import AgentState
from .nodes import (
    make_fetch_purchase,
    aggregate_and_categorize,
    make_fetch_template,
    build_deals,
)


def build_graph(tools: list[BaseTool]) -> StateGraph:
    workflow = StateGraph(AgentState)

    # Deterministic linear pipeline — no model, no decide_route
    workflow.add_node("fetch_purchase", make_fetch_purchase(tools))   # calls get_purchase_deal_data
    workflow.add_node("categorize", aggregate_and_categorize)          # split A/B
    workflow.add_node("fetch_template", make_fetch_template(tools))    # calls get_sales_deal_data
    workflow.add_node("build_deals", build_deals)                      # clone + stage

    workflow.add_edge(START, "fetch_purchase")
    workflow.add_edge("fetch_purchase", "categorize")
    workflow.add_edge("categorize", "fetch_template")
    workflow.add_edge("fetch_template", "build_deals")
    workflow.add_edge("build_deals", END)

    return workflow.compile()  # TODO: persistent checkpointer
